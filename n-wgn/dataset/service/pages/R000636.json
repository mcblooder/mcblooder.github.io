  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Removal and installation of steering column"
    },
    {
      "type": "attention",
      "items": [
        "If there are components of the SRS airbag system in the vicinity, refer to the work precautions and configuration drawings described for the SRS airbag system before proceeding."
      ]
    },
    {
      "type": "attention",
      "items": [
        "Do not release the lock lever of the steering column until the column has been removed and installed."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. 12V battery Negative (-) terminal Disconnect",
      "refs": [
        {
          "id": "R000910",
          "label": "12V battery Negative (-) terminal Disconnect",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Steering wheel removal",
      "refs": [
        {
          "id": "R000634",
          "label": "Steering wheel removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "attention",
      "items": [
        "Always remove the steering wheel before disconnecting the steering joint as damage to the cable reel may result."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Driver lower cover removal",
      "refs": [
        {
          "id": "R000771",
          "label": "Driver lower cover removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Remove the steering upper column cover and lower column cover.",
      "refs": [
        {
          "id": "R000786",
          "label": "Remove the steering upper column cover and lower column cover.",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Remove steering joint cover"
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581852_3.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Steering joint disconnection"
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581853_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Loosen the joint bolt (A) on the intermediate shaft side of the steering joint. Remove the joint bolt (B)."
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581854_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Disconnect the steering joint (A) from the pinion shaft (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Combination switch coupler removal"
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581855_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A). Remove the harness clip (B)."
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581856_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Disconnect the coupler (A). Remove the harness clip (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Combination switch removal"
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581857_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the combination switch (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Steering column removal"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the steering column assembly (A)."
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581858_3.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Intermediate shaft removal",
      "refs": [
        {
          "id": "R000637",
          "label": "Intermediate shaft removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "attention",
      "items": [
        "If there are components of the SRS airbag system in the vicinity, refer to the work precautions and configuration drawings described for the SRS airbag system before proceeding."
      ]
    },
    {
      "type": "attention",
      "items": [
        "Do not release the lock lever of the steering column until the column has been removed and installed."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Intermediate Shaft Mounting",
      "refs": [
        {
          "id": "R000637",
          "label": "Intermediate Shaft Mounting",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Steering Column Installation"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the steering column assembly (A)."
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581859_3.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Combination switch installation"
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581860_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the combination switch (A) on the steering column (B)."
    },
    {
      "type": "attention",
      "items": [
        "Screws shall be tightened in the order shown in the figure."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Combination switch Coupler connection"
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581861_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect the coupler (A). Attach harness clip (B)."
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581862_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Connect the coupler (A). Attach harness clip (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Steering Upper Column Cover, Lower Column Cover Installation",
      "refs": [
        {
          "id": "R000786",
          "label": "Steering Upper Column Cover, Lower Column Cover Installation",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Steering joint connection"
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581863_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Insert the steering joint (A) into the pinion shaft (B)."
    },
    {
      "type": "attention",
      "items": [
        "The pinion shaft shall not be rotated to prevent the rack from changing its linear position."
      ]
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581864_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Align the pinion shaft cutout (A) with the bolt holes in the steering joint and tighten to the specified torque using new joint bolts (B). Tighten the new intermediate shaft side joint bolt (C) to the specified torque. Pull the steering joint toward the column to make sure it does not come loose from the pinion shaft."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Steering joint cover installation"
    },
    {
      "type": "figure",
      "asset": "636_3.0_jpn_11581865_3.0_disp.png"
    },
    {
      "type": "attention",
      "items": [
        "After installation, inspect the steering joint cover for any looseness, looseness, or floating. If any abnormality is found, replace it with a new one."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Driver Lower Cover Installation",
      "refs": [
        {
          "id": "R000771",
          "label": "Driver Lower Cover Installation",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Steering wheel mounting",
      "refs": [
        {
          "id": "R000634",
          "label": "Steering wheel mounting",
          "resolved": true
        }
      ]
    },
    {
      "type": "attention",
      "items": [
        "The steering rack and steering wheel must be in the same linear position."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Tilt operation check"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "11. 12V battery Minus (-) terminal Connection",
      "refs": [
        {
          "id": "R000910",
          "label": "12V battery Minus (-) terminal Connection",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. VSA sensor Midpoint write",
      "refs": [
        {
          "id": "R000714",
          "label": "VSA sensor Midpoint write",
          "resolved": true
        }
      ]
    }
  ],
