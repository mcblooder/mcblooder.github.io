    {
      "type": "step",
      "number": "1",
      "text": "Measure the strain on the cylinder block mating surfaces of the cylinder head."
    },
    {
      "type": "attention",
      "items": [
        "The measurement shall be made without scratching or dents on the gasket mating surface of the cylinder head.",
        "If the strain is greater than the standard value, it shall be corrected within the standard height of the cylinder head."
      ]
    },
