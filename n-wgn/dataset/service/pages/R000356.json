    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect purge hose (A). Connect the fuel feed tube (B) and install the fuel tube cover (C).",
      "refs": [
        {
          "id": "R000483",
          "label": "Connect the fuel feed tube (B) and install the fuel tube cover (C).",
          "resolved": true
        }
      ]
    },
