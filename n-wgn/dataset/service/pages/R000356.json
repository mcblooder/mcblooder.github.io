    {
      "type": "step",
      "number": "1",
      "text": "Install relay box stay (A). Install the A/C tube clamp (B). Install the harness clamp (C). Connect the coupler (D)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "27. Relay box power cable Connection"
    },
    {
      "type": "figure",
      "asset": "356_3.0_jpn_11582705_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the relay box (A). Connect the coupler (B). Connect the power cable (C) to the relay box."
    },
    {
