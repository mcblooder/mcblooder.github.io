  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "VTC actuator inspection"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Intake camshaft removal",
      "refs": [
        {
          "id": "R002131",
          "label": "Intake camshaft removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. VTC actuator Inspection"
    },
    {
      "type": "figure",
      "asset": "366_3.0_jpn_11034067_3.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "366_3.0_jpn_11034068_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Turn the VTC actuator to the left or right and confirm that it is locked."
    },
    {
      "type": "attention",
      "items": [
        "If the VTC actuator is not locked, the VTC actuator shall be replaced."
      ]
    },
    {
      "type": "step",
      "number": "2",
      "text": "Cover the VTC slow angle hole (A) on the intake camshaft with vinyl tape and secure with tie wrap."
    },
    {
      "type": "figure",
      "asset": "366_3.0_jpn_11034069_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Seal one of the VTC advance holes (A) on the intake camshaft with vinyl tape."
    },
    {
      "type": "figure",
      "asset": "366_3.0_jpn_11034070_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Apply air through the advance hole (A) not blocked by the vinyl tape to release the lock pin."
    },
    {
      "type": "figure",
      "asset": "366_3.0_jpn_11034071_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Check that the VTC actuator moves smoothly, and if it does not move smoothly, replace the VTC actuator."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
