      "type": "heading",
      "level": 1,
      "text": "A/C Compressor Relief Valve Removal and Installation"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Front license plate removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Recovery of refrigerant",
      "refs": [
        {
          "id": "R002698",
          "label": "Recovery of refrigerant",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Compressor relief valve removal"
    },
    {
      "type": "figure",
      "asset": "881_5.0_jpn_11580988_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the compressor relief valve (A)."
    },
    {
      "type": "attention",
      "items": [
        "A relief valve that has blown out refrigerant once should be replaced."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Precautions for installation work"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "attention",
      "items": [
        "The O-ring must be replaced with a new one and lubricated with compressor oil (SP-10) before installation."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Vacuuming/leak testing/refrigerant sealing",
      "refs": [
        {
          "id": "R002698",
          "label": "Vacuuming/leak testing/refrigerant sealing",
          "resolved": true
        }
      ]
    },
    {
      "type": "step",
      "number": "1",
      "text": "After installation, perform vacuuming, leak test, and refrigerant sealing."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. performance test",
      "refs": [
        {
          "id": "R000907",
          "label": "performance test",
          "resolved": true
        }
      ]
    }
