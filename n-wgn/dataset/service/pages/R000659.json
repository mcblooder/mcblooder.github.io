  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Removing and installing wheels"
    },
    {
      "type": "paragraph",
      "text": "Figure shows the front side."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Lift Set",
      "refs": [
        {
          "id": "G000319",
          "label": "Lift Set",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Wheel removal"
    },
    {
      "type": "figure",
      "asset": "659_3.0_jpn_11035684_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Loosen the wheel nut (A). Jack up the vehicle to lift the wheels."
    },
    {
      "type": "attention",
      "items": [
        "When jacking up the front wheels, be sure to apply the parking brake and secure the wheels to the rear wheels.",
        "When jacking up the rear wheels, be sure to use wheel stops on the front wheels."
      ]
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the wheel nuts and remove the wheel."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure. Clean the mating surfaces of the wheel and brake disc or brake drum before mounting."
    }
  ],
