  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Brake pedal removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Driver lower cover removal",
      "refs": [
        {
          "id": "R000771",
          "label": "Driver lower cover removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Steering lower column cover removal",
      "refs": [
        {
          "id": "R000786",
          "label": "Steering lower column cover removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Brake switch removal"
    },
    {
      "type": "figure",
      "asset": "699_3.0_jpn_11035934_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A). Remove the harness clip (B). Turn the brake switch (C) 45° counterclockwise and remove it."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Brake pedal removal"
    },
    {
      "type": "figure",
      "asset": "699_3.0_jpn_11035935_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the clip (A) and pedal pin (B). Remove the brake pedal support stay (C). Remove the master power mounting nut (D). Remove the brake pedal (E)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Brake pedal mounting"
    },
    {
      "type": "figure",
      "asset": "699_3.0_jpn_11035936_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the brake pedal (A). Install master power mounting nut (B). Install the brake pedal stay (C). Attach the joint pin (G) and clip (H). Install the joint pin clips as shown in Figure (I)."
    },
    {
      "type": "attention",
      "items": [
        "Flange bolts (D) and (F) shall be temporarily tightened in this order, and then tightened in the order of (D), (E), and (F) to the specified torque."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Brake switch installation"
    },
    {
      "type": "figure",
      "asset": "699_3.0_jpn_11035937_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Push in the brake switch (A) until the threaded end of the switch touches the pedal stop bracket. Turn the brake switch clockwise 45° to install it on the brake pedal (B). Install the harness clip (C). Connect the coupler (D)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Brake pedal height Inspection",
      "refs": [
        {
          "id": "R000683",
          "label": "Brake pedal height Inspection",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Steering Lower Column Cover Installation",
      "refs": [
        {
          "id": "R000786",
          "label": "Steering Lower Column Cover Installation",
          "resolved": true
        }
      ]
    },
