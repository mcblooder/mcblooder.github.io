    {
      "type": "heading",
      "level": 3,
      "text": "1. Evaporator sensor Inspection"
    },
    {
      "type": "figure",
      "asset": "873_5.0_jpn_11580958_5.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "873_5.0_jpn_11580959_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Check that the resistance between the No. 1 and No. 2 terminals of the evaporator sensor is within the range shown in the graph."
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Place the sensor part in water with ice to cool it down and measure the resistance value. Next, check the change in resistance value while pouring hot water."
        },
        {
          "text": "Place the sensor part in water with ice to cool it down and measure the resistance value. Next, check the change in resistance value while pouring hot water."
        },
        {
          "text": "Since the inside of the sensor is a thermistor, a digital circuit tester should be used since a large measurement current will cause self-heating."
        },
        {
          "text": "Since the inside of the sensor is a thermistor, a digital circuit tester should be used since a large measurement current will cause self-heating."
        },
        {
          "text": "Measure in a location where the ambient temperature is stable."
        },
        {
          "text": "Measure in a location where the ambient temperature is stable."
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Evaporator Sensor Mounting"
    },
    {
      "type": "figure",
      "asset": "873_5.0_jpn_11580960_5.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "873_5.0_jpn_11580961_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Check the evaporator sensor mounting position."
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "When replacing the evaporator (A) with a new one, install the evaporator sensor (B) in the factory position."
        },
        {
          "text": "When replacing the evaporator (A) with a new one, install the evaporator sensor (B) in the factory position."
        },
        {
          "text": "When reusing the evaporator (C), shift the evaporator sensor (D) from its original position to the next row."
        },
        {
          "text": "When reusing the evaporator (C), shift the evaporator sensor (D) from its original position to the next row."
        }
      ]
    },
