    {
      "type": "heading",
      "level": 3,
      "text": "23. Instrument panel removal"
    },
    {
      "type": "figure",
      "asset": "788_3.0_jpn_11581278_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the bolt from the passenger airbag mount bracket (A). Disconnect harness clips (B and C)."
    },
    {
      "type": "figure",
      "asset": "788_3.0_jpn_11581279_4.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the bolt (A) and screw (B). Pull the instrument panel (C) toward you while slightly lifting it up and disconnect the harness clip (D). Remove the instrument panel from the front door opening to the outside."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "24. Instrument duct removal"
    },
    {
      "type": "figure",
      "asset": "788_3.0_jpn_11581280_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the driver holder (A). Remove the center holder (B). Remove the instrument duct (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "25. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
