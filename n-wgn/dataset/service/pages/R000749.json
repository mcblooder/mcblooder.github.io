    {
      "type": "heading",
      "level": 3,
      "text": "1. Roof Lining Cap Removal"
    },
    {
      "type": "figure",
      "asset": "749_3.0_jpn_11337714_3.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Room mirror removal"
    },
    {
      "type": "figure",
      "asset": "749_3.0_jpn_11036207_4.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the room mirror (A)."
    },
    {
      "type": "figure",
      "asset": "749_3.0_jpn_11337706_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Vehicles equipped with rear seat belt indicator: Remove the harness cap (A). Vehicles equipped with rear seat belt indicator: Disconnect the coupler (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Room mirror stay base removal"
    },
    {
      "type": "figure",
      "asset": "749_3.0_jpn_11036208_4.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the lock washer (A) and room mirror stay base (B) from the room mirror (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
