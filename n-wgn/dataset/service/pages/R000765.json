  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Grab rail removal and inspection"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Grab rail removal"
    },
    {
      "type": "figure",
      "asset": "765_3.0_jpn_11397700_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Lower the grab rail (A) and remove the stopper (B). Remove the grab rail by pinching the clip (C) with a pair of pliers or similar tool."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Grab rail Inspection"
    },
    {
      "type": "figure",
      "asset": "765_3.0_jpn_11397709_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Vehicles equipped with side curtain airbags: If the side curtain airbags are deployed, replace them with new grab rails. Vehicles equipped with side curtain airbags: If the side curtain airbags are not deployed, inspect the grab rails (A) and stoppers (B) and replace if damaged, cracked or whitened."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Grab rail mounting"
    },
    {
      "type": "figure",
      "asset": "765_3.0_jpn_11397701_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Align the grab rail (A) with the grab rail mounting hole position (B) and press the clip (C) into place. Install the stopper (D). Ensure that the grab rail does not come off."
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131015114331/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R000765_jpn/web/html/R000765_jpn_Content.html",
