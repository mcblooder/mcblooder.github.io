  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Front Seat Back Trim Cover/Pad Removal"
    },
    {
      "type": "attention",
      "items": [
        "If there are components of the SRS airbag system in the vicinity, refer to the work precautions and configuration drawings described for the SRS airbag system before proceeding."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. 12V battery Negative (-) terminal Disconnect",
      "refs": [
        {
          "id": "R000910",
          "label": "12V battery Negative (-) terminal Disconnect",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Front seat removal",
      "refs": [
        {
          "id": "R000792",
          "label": "Front seat removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Front seat reclining cover removal",
      "refs": [
        {
          "id": "R002709",
          "label": "Front seat reclining cover removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Remove front seat back/cushion assembly."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581345_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the hook (A)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581346_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the connecting harness clip (A) of the passenger seat seating switch and seat belt buckle from the rotating device (B)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581347_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the side airbag harness (A) from the rotating device (B)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581348_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Pull the side airbag harness (A) out of the seat cushion trim cover (B)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581349_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Remove the cap (A), bolt, bushing (B) and washer (C), and remove the armrest (D)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581350_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Remove the ring (A) and bolt, and remove the pivot (B)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581351_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Remove the front seat back/cushion assembly (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Remove front seat back trim cover/pad"
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581352_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the hook (A) and pull up the zipper (B)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581353_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Turn up the seat back trim cover (A) and remove the hook (B)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581354_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the harness clip (A) of the side airbag."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581355_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the nut on the inside of the seat."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581356_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Remove the headrest guide (A)."
    },
    {
      "type": "figure",
      "asset": "2711_3.0_jpn_11581357_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Remove the front seat back trim cover/pad (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131120133233/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R002711_jpn/web/html/R002711_jpn_Content.html",
  "inOutline": true
}