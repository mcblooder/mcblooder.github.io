          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. Right side front bulkhead box removal"
    },
    {
      "type": "figure",
      "asset": "2917_5.0_jpn_11677575_3.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "13. Tighten side engine mount brackets."
    },
    {
      "type": "figure",
      "asset": "2917_5.0_jpn_11582811_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Temporarily tighten the new side engine mount bracket mounting nut (A) and loosen the side engine mount bracket mounting bolt (B). Perform the side engine mount tightening procedure.",
      "refs": [
        {
          "id": "R000357",
          "label": "Perform the side engine mount tightening procedure.",
          "resolved": true
        }
      ]
    },
    {
      "type": "attention",
      "items": [
        "If the side engine mount bracket fasteners are removed, the transmission mount and torque rod must be tightened in the correct sequence."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "14. Right side front bulkhead box installation"
    },
    {
      "type": "figure",
      "asset": "2917_5.0_jpn_11677576_3.0_disp.png"
    },
    {
