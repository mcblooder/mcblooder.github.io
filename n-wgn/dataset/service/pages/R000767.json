    {
      "type": "heading",
      "level": 3,
      "text": "8. Floor carpet removal"
    },
    {
      "type": "figure",
      "asset": "767_3.0_jpn_11388830_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Cut a notch (B) in the center of the floor carpet (A) below the heater unit. Remove the clip. Pull the floor harness (C) through the hole (D) in the floor carpet and under the carpet. Fold the floor carpet lightly and remove it from the room."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Front floor spacer removal"
    },
    {
      "type": "figure",
      "asset": "767_3.0_jpn_11388831_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "If necessary, remove the floor spacer (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
