  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Front door outer handle removal"
    },
    {
      "type": "paragraph",
      "text": "Glass should be raised."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Front door lining removal",
      "refs": [
        {
          "id": "R000720",
          "label": "Front door lining removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Front door hole seal removal"
    },
    {
      "type": "figure",
      "asset": "721_3.0_jpn_11581056_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the plug cap (A). Disconnect the coupler (B). Remove the harness clip (C). Remove the front door hole seal (D) as required. If the front door hall seal is damaged or torn, replace it with a new front door hall seal."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Front door outer handle removal"
    },
    {
      "type": "figure",
      "asset": "721_3.0_jpn_11581057_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A) and remove the harness clip (B)."
    },
    {
      "type": "figure",
      "asset": "721_3.0_jpn_11581058_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Turn and remove the joint bushing (A) and use the clip remover to disconnect the outer handle rod (B)."
    },
    {
      "type": "figure",
      "asset": "721_3.0_jpn_11581059_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the bolt."
    },
    {
      "type": "figure",
      "asset": "721_3.0_jpn_11581060_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "While pulling the front door outer handle (A), remove it from the hole in the door panel as shown."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Joint bushing removal"
    },
    {
      "type": "figure",
      "asset": "721_3.0_jpn_11581061_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the joint bushing (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "attention",
      "items": [
        "Joint bushings shall be replaced with new ones."
      ]
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131120133233/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R000721_jpn/web/html/R000721_jpn_Content.html",
