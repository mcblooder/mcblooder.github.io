  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Replace pulley end crankshaft oil seal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Crankshaft pulley removal",
      "refs": [
        {
          "id": "R000368",
          "label": "Crankshaft pulley removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Pulley end Crankshaft oil seal removal"
    },
    {
      "type": "figure",
      "asset": "393_5.0_jpn_11582980_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Pulley End Crankshaft Oil Seal Installation"
    },
    {
      "type": "figure",
      "asset": "393_5.0_jpn_11582981_5.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "393_5.0_jpn_11582982_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove oil and dirt from pulley end crankshaft oil seal housing. Apply engine oil to the lip of the pulley end crankshaft oil seal with your finger. Using the remover base 47 × 49 (07HAF-SF10130), securely drive the pulley end crankshaft oil seal into the chain case."
    },
    {
      "type": "attention",
      "items": [
        "The oil seal must be installed with the part number facing outward."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Crankshaft pulley Installation",
      "refs": [
        {
          "id": "R000368",
          "label": "Crankshaft pulley Installation",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Front bumper removal",
      "refs": [
        {
          "id": "R000814",
          "label": "Front bumper removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Front upper grille removal",
      "refs": [
        {
          "id": "R000842",
          "label": "Front upper grille removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Right side front bulkhead box removal"
    },
    {
      "type": "figure",
      "asset": "393_5.0_jpn_11677581_3.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Tighten side engine mount brackets."
    },
    {
      "type": "figure",
      "asset": "393_5.0_jpn_11582983_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Temporarily tighten the new side engine mount bracket mounting nut (A) and loosen the side engine mount bracket mounting bolt (B). Perform the side engine mount tightening procedure.",
      "refs": [
        {
          "id": "R000357",
          "label": "Perform the side engine mount tightening procedure.",
          "resolved": true
        }
      ]
    },
    {
      "type": "attention",
      "items": [
        "If the side engine mount bracket fasteners are removed, the transmission mount and torque rod must be tightened in the correct sequence."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Right side front bulkhead box installation"
    },
    {
      "type": "figure",
