    {
      "type": "heading",
      "level": 2,
      "text": "Failure Criteria"
    },
    {
      "type": "paragraph",
      "text": "Driven Pulley Speed When the sensor rotation direction output signal continues to indicate reverse rotation for more than 2 seconds during forward travel."
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Estimated Failure Site"
    },
    {
      "type": "list",
      "ordered": false,
