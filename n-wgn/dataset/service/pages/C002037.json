      "text": "Headlight leveling system structure description - Fail-safe function - Auto leveling system"
    },
    {
      "type": "paragraph",
      "text": "Optical axis control is not performed if any of the following items apply"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Abnormality of leveling sensor"
        },
        {
          "text": "Abnormality of B-CAN input"
        },
        {
          "text": "Headlight leveling motor failure"
        },
        {
          "text": "Combination switch information is abnormal."
        },
        {
          "text": "Abnormal vehicle speed information"
        },
        {
          "text": "Headlight auto-leveling control unit has not learned the initial position."
        },
        {
          "text": "12V battery voltage less than 10V"
        }
      ]
    }
