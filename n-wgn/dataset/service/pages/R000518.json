          }
        ]
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "failure phenomenon",
            "header": true
          },
          {
            "text": "Estimated Failure Location",
            "header": true
          }
        ],
        [
          {
            "text": "No or low drive pulley pressure"
          },
          {
            "text": "Oil pumps PH regulator valve DR Control Valve Clutch Reducing Valve Drive Pulley Control SOL.V."
          }
        ],
        [
          {
            "text": "High drive pulley pressure"
          },
          {
            "text": "PH regulator valve DR Control Valve Clutch Reducing Valve Drive Pulley Control SOL.V."
          }
        ]
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Driven Pulley pressure Measurement"
    },
    {
      "type": "figure",
      "asset": "518_5.0_jpn_11582136_5.0_disp.png"
