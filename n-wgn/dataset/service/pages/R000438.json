  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Removal and Installation of Radiator"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Front under cover removal",
      "refs": [
        {
          "id": "R000850",
          "label": "Front under cover removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Cooling water removal",
      "refs": [
        {
          "id": "R000435",
          "label": "Cooling water removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Lower hose/coupler (radiator water temperature sensor) Disconnect"
    },
    {
      "type": "figure",
      "asset": "438_5.0_jpn_11583103_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the lower hose (A). Disconnect the coupler (B) and remove the clamp (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Lift Down"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Front bumper removal",
      "refs": [
        {
          "id": "R000814",
          "label": "Front bumper removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Front upper grille removal",
      "refs": [
        {
          "id": "R000842",
          "label": "Front upper grille removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Bumper beam removal"
    },
    {
      "type": "figure",
      "asset": "438_5.0_jpn_11583104_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the harness clamp (A) on the A/C compressor and remove the bumper beam."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Intercooler Guide B removal (turbo charger equipped vehicles)"
    },
    {
      "type": "figure",
      "asset": "438_5.0_jpn_11583105_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Reserve tank removal"
    },
    {
      "type": "figure",
      "asset": "438_5.0_jpn_11583106_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Upper hose/coupler (fan motor) Disconnect"
    },
    {
      "type": "figure",
      "asset": "438_5.0_jpn_11583107_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A) and remove the clamp (B). Disconnect the upper hose (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "11. Radiator upper bracket removal"
    },
    {
      "type": "figure",
      "asset": "438_5.0_jpn_11583108_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the water filler mounting bolt (A). Disconnect the outside temperature sensor coupler (B) and remove the clamp (C). Remove the radiator upper bracket (D) and remove the condenser mounting bolt (E). Loosen the capacitor mounting bolt (F) and shift the capacitor."
    },
    {
      "type": "attention",
      "items": [
        "Do not disconnect the discharge hose and receiver pipe.",
        "Do not bend the receiver pipe."
      ]
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Do not disconnect the discharge hose and receiver pipe."
        },
        {
          "text": "Do not disconnect the discharge hose and receiver pipe."
        },
        {
          "text": "Do not bend the receiver pipe."
        },
        {
          "text": "Do not bend the receiver pipe."
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. Radiator removal"
    },
    {
      "type": "figure",
      "asset": "438_5.0_jpn_11583110_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Pull up the radiator (A), remove the radiator fan shroud assembly (B), radiator water temperature sensor (C) and drain cock (D), and disconnect the water filler hose (E)."
    },
    {
      "type": "attention",
      "items": [
        "Lower cushion (F) shall be set securely."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "13. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "14. Coolant Injection",
      "refs": [
        {
          "id": "R000435",
          "label": "Coolant Injection",
          "resolved": true
        }
      ]
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131205174356/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R000438_jpn/web/html/R000438_jpn_Content.html",
  "inOutline": true
}