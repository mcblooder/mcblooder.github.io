      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. runout inspection"
    },
    {
      "type": "figure",
      "asset": "687_5.0_jpn_11581577_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Secure the brake disc with the wheel nut (B) through an appropriate flat washer (A) so as not to damage the tapered portion of the wheel nut. Place the dial gauge (C) as shown in the figure at a position about 10 mm closer to the center from the outer circumference of the disc. Turn the disc slowly by hand to measure the runout. The minimum to maximum range of the gauge reading is the runout value. If it is below the limit, inspect the hub bearings, and if there is nothing wrong with the bearings, cut and correct the brake disk."
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Limit value: 1"
          },
          {
            "text": "0.04mm"
          }
        ]
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Front brake pad installation",
      "refs": [
        {
          "id": "R002922",
          "label": "Front brake pad installation",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Front wheel mounting",
      "refs": [
        {
