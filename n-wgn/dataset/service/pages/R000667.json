  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Front stabilizer removal and installation"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Lift Set",
      "refs": [
        {
          "id": "G000319",
          "label": "Lift Set",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Front wheel removal",
      "refs": [
        {
          "id": "R000659",
          "label": "Front wheel removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Front under cover removal",
      "refs": [
        {
          "id": "R000850",
          "label": "Front under cover removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Driver's side front splash guard clip removal"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581760_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the clip (A) on the driver side front splash guard."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Remove steering joint cover"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581761_3.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Tilt position to uppermost"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Release the lock lever and set the column in the highest tilt position. Lock the lock lever."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Steering wheel holder mounting"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581762_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Place the steering wheel in the straight ahead position and install the steering wheel holder (aftermarket tool) (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Steering joint disconnection"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581763_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Loosen the joint bolt (A) on the intermediate shaft side of the steering joint. Remove the joint bolt (B)."
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581764_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Disconnect the steering joint (A) from the pinion shaft (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Stabilizer link disconnect"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581765_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the stabilizer (A) from the stabilizer link (B). Hold the joint pin (C) with the hex wrench (D) and loosen the flange nut (E)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Tie rod end disconnect"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581766_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the split pin (B) from the ball joint connection of the tie rod end (A), and remove the nut (C). Disconnect the tie rod end from the knuckle using the special tool.",
      "refs": [
        {
          "id": "R000660",
          "label": "Disconnect the tie rod end from the knuckle using the special tool.",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "11. Exhaust pipe/silencer removal",
      "refs": [
        {
          "id": "R000416",
          "label": "Exhaust pipe/silencer removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. Propeller shaft removal (4WD vehicles)",
      "refs": [
        {
          "id": "R000615",
          "label": "Propeller shaft removal (4WD vehicles)",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "13. Engine Support"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581767_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Support the center of the oil pan with a jack (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "14. Torque rod removal",
      "refs": [
        {
          "id": "R000359",
          "label": "Torque rod removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "15. Subframe disconnect"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581768_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Support the sub-frame (A) with the transmission jack (B) by placing a square timber or similar object against the sub-frame (A). Remove the sub-frame mounting bolt (C). Remove the underload pass rod mounting bolt (D). Lower the subframe with the transmission jack until the lower arm is level."
    },
    {
      "type": "attention",
      "items": [
        "Do not lower the subframe too far than necessary."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "16. Stabilizer removal"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581769_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the stabilizer bushing holder (A) and the stabilizer bushing (B), and remove the stabilizer (C). Remove the stabilizer from the passenger side."
    },
    {
      "type": "attention",
      "items": [
        "When removing the stabilizer, be careful not to damage the steering gear box."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Stabilizer installation"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581770_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Pull the stabilizer into the installation position from the passenger side and install it with the stabilizer bushing holder (A) and the stabilizer bushing (B)."
    },
    {
      "type": "attention",
      "items": [
        "When installing the stabilizer, be careful not to damage the steering gear box."
      ]
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Align the end face of the stabilizer bushing with the stabilizer band (C)."
        },
        {
          "text": "Align the end face of the stabilizer bushing with the stabilizer band (C)."
        },
        {
          "text": "The arrow (D) on the ''FR'' mark on the side of the stabilizer bushing should point to the front side."
        },
        {
          "text": "The arrow (D) on the ''FR'' mark on the side of the stabilizer bushing should point to the front side."
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Subframe Connection"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581771_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Flip the lip (A) of the pinion shaft grommet outward. Lift the sub-frame (B) up to the body by supporting it with the transmission jack (C) using a square timber, etc. Restore inversion of the lip of the pinion shaft grommet. Temporarily install the new subframe mounting bolts (D). Temporarily attach the underload pass rod mounting bolt (E)."
    },
    {
      "type": "attention",
      "items": [
        "Pinion shaft grommets shall not be dislodged or displaced, and the lips shall not be turned up. Poor installation may cause mud, water, or noise intrusion into the interior."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Subframe Tightening",
      "refs": [
        {
          "id": "R000865",
          "label": "Subframe Tightening",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Anda Load Path Rod Tightening",
      "refs": [
        {
          "id": "R000864",
          "label": "Anda Load Path Rod Tightening",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Torque Rod Mounting",
      "refs": [
        {
          "id": "R000359",
          "label": "Torque Rod Mounting",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Jack Removal"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581772_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the jack (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Propeller Shaft Installation (4WD models)",
      "refs": [
        {
          "id": "R000615",
          "label": "Propeller Shaft Installation (4WD models)",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Exhaust pipe/silencer installation",
      "refs": [
        {
          "id": "R000416",
          "label": "Exhaust pipe/silencer installation",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Stabilizer Link Connection"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581773_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect the stabilizer (A) to the stabilizer link (B) and tighten the new flange nut (C) to the specified torque. Hold the joint pin (D) with an Allen wrench (E) and tighten the nut."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Tie Rod End Connection"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581774_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect the tie rod end (A) to the knuckle."
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "If the tie rod lock nuts (B) are loosened, they should be tightened when adjusting the front toe."
        },
        {
          "text": "If the tie rod lock nuts (B) are loosened, they should be tightened when adjusting the front toe."
        },
        {
          "text": "Replace the split pin (C) with a new one and bend it as shown in (D) or (E) in the figure."
        },
        {
          "text": "Replace the split pin (C) with a new one and bend it as shown in (D) or (E) in the figure."
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "11. Steering joint connection"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581775_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Insert the steering joint (A) into the pinion shaft (B)."
    },
    {
      "type": "attention",
      "items": [
        "The pinion shaft shall not be rotated to prevent the rack from changing its linear position."
      ]
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581776_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Align the pinion shaft cutout (A) with the bolt holes in the steering joint and tighten to the specified torque using new joint bolts (B). Tighten the new intermediate shaft side joint bolt (C) to the specified torque. Pull the steering joint toward the column to make sure it does not come loose from the pinion shaft."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. Steering wheel holder removal"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581777_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the steering wheel holder (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "13. Steering joint cover installation"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581778_3.0_disp.png"
    },
    {
      "type": "attention",
      "items": [
        "After installation, inspect the steering joint cover for any looseness, looseness, or floating. If any abnormality is found, replace it with a new one."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "14. Driver's side Front splash guard clip installation"
    },
    {
      "type": "figure",
      "asset": "667_3.0_jpn_11581779_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the clip (A) of the driver side front splash guard."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "15. Front Under Cover Installation",
      "refs": [
        {
          "id": "R000850",
          "label": "Front Under Cover Installation",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "16. Front wheel mounting",
      "refs": [
        {
          "id": "R000659",
          "label": "Front wheel mounting",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "17. Tilt operation check"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "18. Wheel alignment Inspection and adjustment"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Set the tilt position near the center, drive straight ahead, and check that the steering wheel is in the straight ahead position. If adjustment is necessary, turn the tie rods by the same amount on both sides. Check and adjust wheel alignment. If there is a left-right difference in the front wheel angle of turn, correct the serration engagement between the steering joint and shaft, and then adjust the toe.",
      "refs": [
        {
          "id": "R000655",
          "label": "Check and adjust wheel alignment.",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "19. VSA sensor Midpoint write",
      "refs": [
        {
          "id": "R000714",
          "label": "VSA sensor Midpoint write",
          "resolved": true
        }
      ]
    }
  ],
