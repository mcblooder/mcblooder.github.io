    {
      "type": "heading",
      "level": 1,
      "text": "Adjustment of door glass erection"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Work should be performed in a horizontal state."
        },
        {
          "text": "Work should be performed in a horizontal state."
        },
        {
          "text": "Inspect glass run channels and weatherstripping for damage, etc., and replace any that have deteriorated significantly."
        },
        {
          "text": "Inspect glass run channels and weatherstripping for damage, etc., and replace any that have deteriorated significantly."
        }
      ]
    },
