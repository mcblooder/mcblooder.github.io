  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Front Door Key Cylinder Removal and Installation"
    },
    {
      "type": "paragraph",
      "text": "Glass should be raised."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Front door lining removal",
      "refs": [
        {
          "id": "R000720",
          "label": "Front door lining removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Front door hole seal removal"
    },
    {
      "type": "figure",
      "asset": "723_3.0_jpn_11337152_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the plug cap (A). Disconnect the coupler (B). Remove the harness clip (C). Remove the front door hole seal (D) as required. If the front door hall seal is damaged or torn, replace it with a new front door hall seal."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Front door key cylinder removal"
    },
    {
      "type": "figure",
      "asset": "723_3.0_jpn_11337153_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Turn and remove the joint bushing (A) and disconnect the key cylinder rod (B)."
    },
    {
      "type": "figure",
      "asset": "723_3.0_jpn_11337154_2.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "723_3.0_jpn_11337155_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the retainer plate (A) and remove the key cylinder (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
