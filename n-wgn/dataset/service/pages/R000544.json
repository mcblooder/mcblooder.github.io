    {
      "type": "figure",
      "asset": "544_5.0_jpn_11582217_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the transmission mount (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "21. Sub hanger stay removal"
    },
    {
