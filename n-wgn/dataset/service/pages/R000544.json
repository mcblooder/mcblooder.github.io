  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "CVT transmission removal"
    },
    {
      "type": "paragraph",
      "text": "*Specified commercial tools"
    },
    {
      "type": "attention",
      "items": [
        "Garage jacks, rigid racks, and lifts should be securely applied in place.",
        "For safety reasons, the removed wheels should be placed under the side sills behind the rigid rack.",
        "Use fender covers to avoid scratching painted surfaces.",
        "When disconnecting wiring, hold the coupler connector and disconnect gently to avoid disconnection. Also, make sure that cords and tubes do not become entangled or come into contact with other parts of the product."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Lift Set",
      "refs": [
        {
          "id": "G000319",
          "label": "Lift Set",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Steering joint disconnection",
      "refs": [
        {
          "id": "R000640",
          "label": "Steering joint disconnection",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Hood Open"
    },
    {
      "type": "figure",
      "asset": "544_5.0_jpn_11582175_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Place the hood in the vertical position and secure with the hood open stay (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Front bumper removal",
      "refs": [
        {
          "id": "R000814",
          "label": "Front bumper removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Front upper grille removal",
      "refs": [
        {
          "id": "R000842",
          "label": "Front upper grille removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Cowl top removal",
      "refs": [
        {
          "id": "R000846",
          "label": "Cowl top removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. 12V battery removal",
      "refs": [
        {
          "id": "R002224",
          "label": "12V battery removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Reserve tank removal"
    },
    {
      "type": "figure",
      "asset": "544_5.0_jpn_11582176_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. 12V battery base removal"
    },
    {
      "type": "figure",
      "asset": "544_5.0_jpn_11582177_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Air cleaner removal"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the air cleaner.",
      "refs": [
        {
          "id": "R000412",
          "label": "Cars not equipped with a turbo charger",
          "resolved": true
        },
        {
          "id": "R000413",
          "label": "Turbo Charger equipped vehicle",
          "resolved": true
        }
      ]
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Cars not equipped with a turbo charger",
          "refs": [
            {
              "id": "R000412",
              "label": "Cars not equipped with a turbo charger",
              "resolved": true
            }
          ]
        },
        {
          "text": "Cars not equipped with a turbo charger",
          "refs": [
            {
