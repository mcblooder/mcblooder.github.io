      ]
    },
    {
      "type": "figure",
      "asset": "544_5.0_jpn_11582220_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Install the harness bracket (A)."
    },
    {
      "type": "attention",
      "items": [
