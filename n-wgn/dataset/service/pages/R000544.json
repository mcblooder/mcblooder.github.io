      "type": "figure",
      "asset": "544_5.0_jpn_11582198_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Hold the inboard joint (A) and pull it out horizontally from the differential."
    },
    {
      "type": "attention",
      "items": [
