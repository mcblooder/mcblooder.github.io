  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Transmission fluid warmer removal"
    },
    {
      "type": "attention",
      "items": [
        "Be very careful to prevent dust and other debris from entering the transmission."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Splash shield removal",
      "refs": [
        {
          "id": "R000849",
          "label": "Splash shield removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Cooling water removal",
      "refs": [
        {
          "id": "R000435",
          "label": "Cooling water removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Transmission Fluid Extraction"
    },
    {
      "type": "figure",
      "asset": "2169_5.0_jpn_11582241_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "With the vehicle in a horizontal position, remove the drain bolt (A) and drain the transmission fluid."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Transmission Fluid Warmer Removal"
    },
    {
      "type": "figure",
      "asset": "2169_5.0_jpn_11582242_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the water hose (A) and remove the transmission fluid warmer (B)."
    },
    {
      "type": "attention",
      "items": [
        "When removing the water hose, be careful not to bend or damage the water pipe."
      ]
    },
    {
      "type": "figure",
      "asset": "2169_5.0_jpn_11582243_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the O-ring (B) from the transmission fluid warmer (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Installation Precautions"
    },
    {
      "type": "figure",
      "asset": "2169_5.0_jpn_11582244_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "attention",
      "items": [
        "Align the transmission fluid warmer alignment mark (A) with the water hose alignment mark (B).",
        "The transmission side mounting surface shall be cleaned.",
        "O-rings shall be replaced with new ones."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Coolant Refill",
      "refs": [
        {
          "id": "R000435",
          "label": "Coolant Refill",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Transmission Fluid Refill",
      "refs": [
        {
          "id": "R000543",
          "label": "Transmission Fluid Refill",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Transmission Fluid Check",
      "refs": [
        {
          "id": "R000542",
          "label": "Transmission Fluid Check",
          "resolved": true
        }
      ]
    }
  ],
