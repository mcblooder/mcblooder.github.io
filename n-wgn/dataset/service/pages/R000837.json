    {
      "type": "heading",
      "level": 3,
      "text": "14. Fuel Lid Opener Cable Removal"
    },
    {
      "type": "figure",
      "asset": "837_3.0_jpn_11372249_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the fuel lid opener (A)."
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the cushion tape (A) and clip (B). Cushion tape should be replaced."
    },
    {
      "type": "figure",
      "asset": "837_3.0_jpn_11390115_2.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "837_3.0_jpn_11372250_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Rotate the fuel lid lock (A) counterclockwise to remove it. Disconnect the fuel lid opener cable (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "15. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
