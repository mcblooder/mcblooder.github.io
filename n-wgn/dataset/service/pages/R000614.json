  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Propeller Shaft Inspection"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Lift Set",
      "refs": [
        {
          "id": "G000319",
          "label": "Lift Set",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Select Lever to N position"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Parking brake release"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Universal joints Inspect joint rattles and boots"
    },
    {
      "type": "figure",
      "asset": "614_3.0_jpn_11336529_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Inspect the connection between the center bearing support (A) and the propeller shaft (B) for looseness. Inspect the boot (C) for cracks or damage. Inspect the universal joints for faulty installation and rattling. If there is anything wrong with the propeller shaft, Replace the propeller shaft with an assembly.",
      "refs": [
        {
          "id": "R000615",
          "label": "Replace the propeller shaft with an assembly.",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Propeller shaft runout inspection"
    },
    {
      "type": "figure",
      "asset": "614_3.0_jpn_11336530_2.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "614_3.0_jpn_11336531_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Set the dial gauge in the center of the No. 1 and No. 2 propeller shafts. Fix one rear wheel and turn the other slowly by hand to rotate the propeller shaft and inspect the propeller shaft for runout. Runout Limit Value: 1 1.5mm If the propeller shaft runout exceeds the limit value, Replace the propeller shaft with an assembly.",
      "refs": [
        {
          "id": "R000615",
          "label": "Replace the propeller shaft with an assembly.",
          "resolved": true
        }
      ]
    }
  ],
