  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Blower unit removal/attachment"
    },
    {
      "type": "attention",
      "items": [
        "If there are components of the SRS airbag system in the vicinity, refer to the work precautions and configuration drawings described for the SRS airbag system before proceeding."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Driver lower cover removal",
      "refs": [
        {
          "id": "R000771",
          "label": "Driver lower cover removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Glove box removal",
      "refs": [
        {
          "id": "R000783",
          "label": "Glove box removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Remove front LF antenna inside car",
      "refs": [
        {
          "id": "R000944",
          "label": "Remove front LF antenna inside car",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Heater Outlet Removal"
    },
    {
      "type": "figure",
      "asset": "875_5.0_jpn_11580965_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the harness clip (A) and remove the heater outlet (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Blower unit removal"
    },
    {
      "type": "figure",
      "asset": "875_5.0_jpn_11580966_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A) and remove the harness clip (B) and coupler clip (C)."
    },
    {
      "type": "figure",
      "asset": "875_5.0_jpn_11580967_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the bracket (A)."
    },
    {
      "type": "figure",
      "asset": "875_5.0_jpn_11580968_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the screw and nut."
    },
    {
      "type": "figure",
      "asset": "875_5.0_jpn_11580969_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Release the lock (A) and lower the lower case (C) while pushing the tabs (B) in the direction of the arrow."
    },
    {
      "type": "attention",
      "items": [
        "Do not damage the wire harness and evaporator core when lowering the lower case."
      ]
    },
    {
      "type": "figure",
      "asset": "875_5.0_jpn_11580970_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Remove the blower unit (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Intake duct removal"
    },
    {
      "type": "figure",
      "asset": "875_5.0_jpn_11580971_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the intake duct (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Precautions for installation work"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure. Make sure there are no air leaks from the blower unit connections."
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131205174356/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R000875_jpn/web/html/R000875_jpn_Content.html",
  "inOutline": true
}