    {
      "type": "heading",
      "level": 1,
      "text": "Inspect cylinder block/piston"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Piston/con-rod assembly removal",
      "refs": [
        {
          "id": "R000392",
          "label": "Piston/con-rod assembly removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Cylinder block inspection"
    },
    {
      "type": "figure",
      "asset": "391_3.0_jpn_11588153_2.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "391_3.0_jpn_11582957_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Measure the wear and taper of the cylinder block bore."
    },
    {
      "type": "step",
      "number": "2",
      "text": "Measure 3 locations each in the X and Y directions."
    },
    {
      "type": "attention",
      "items": [
        "Do not scratch or dent the gasket mating surface of the cylinder block.",
        "If the limit value is exceeded, the cylinder block should be replaced."
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Std."
          },
          {
            "text": "X direction"
          },
          {
            "text": "64.000－64.020mm"
          }
        ],
        [
          {
            "text": ""
          },
          {
            "text": "Y direction"
          },
          {
            "text": "64.000－64.015mm"
          }
        ],
        [
          {
            "text": "Limit value: 1"
          },
          {
            "text": "X direction"
          },
          {
            "text": "64.065mm"
          }
        ],
        [
          {
            "text": ""
          },
          {
            "text": "Y direction"
          },
          {
            "text": "64.065mm"
          }
        ]
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Limit value: 1"
          },
          {
            "text": "0.05mm"
          }
        ]
      ]
    },
    {
      "type": "figure",
      "asset": "391_3.0_jpn_11582958_3.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "391_3.0_jpn_11582959_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Measure the strain on the cylinder block."
    },
    {
      "type": "attention",
      "items": [
        "If the strain is greater than the standard value, the cylinder block should be replaced."
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Std."
          },
          {
            "text": "0.07mm or less"
          }
        ]
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Piston Inspection"
    },
    {
      "type": "figure",
      "asset": "391_3.0_jpn_11582960_3.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "391_3.0_jpn_11582961_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Inspect pistons for strains and cracks and replace if necessary."
    },
    {
      "type": "step",
      "number": "2",
      "text": "Measure the outside diameter (A) of the piston."
    },
    {
      "type": "attention",
      "items": [
        "If it is below the limit value, the piston should be replaced."
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Std."
          },
          {
            "text": "63.970－63.977mm"
          }
        ],
        [
          {
            "text": "Limit value: 1"
          },
          {
            "text": "63.97mm"
          }
        ]
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Std."
          },
          {
            "text": "0.023－0.045mm"
          }
        ],
        [
          {
            "text": "Limit value: 1"
          },
          {
            "text": "0.055mm"
          }
        ]
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
