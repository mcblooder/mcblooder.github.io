  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Rear bumper removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Rear bumper removal"
    },
    {
      "type": "figure",
      "asset": "816_3.0_jpn_11581446_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the bolt (A), screw (B) and clips (C, D)."
    },
    {
      "type": "figure",
      "asset": "816_3.0_jpn_11581447_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Pull the wheel arches on both sides of the rear bumper (A) outward and remove them from the hooks (C) of the rear bumper side spacers (B)."
    },
    {
      "type": "figure",
      "asset": "816_3.0_jpn_11581448_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the rear bumper (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Rear bumper side spacer removal"
    },
    {
      "type": "figure",
      "asset": "816_3.0_jpn_11581449_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "If necessary, remove the rear bumper side spacers (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
