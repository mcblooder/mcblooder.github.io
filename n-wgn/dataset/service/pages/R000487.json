  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Fuel sender unit removal and installation"
    },
    {
      "type": "attention",
      "items": [
        "Fire is strictly prohibited. ​",
        "Removal should be performed with the engine stopped and the battery (-) terminal disconnected. ​"
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Fuel pump removal",
      "refs": [
        {
          "id": "R000488",
          "label": "Fuel pump removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Fuel sender unit removal"
    },
    {
      "type": "figure",
      "asset": "487_3.0_jpn_11582609_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the coupler (A). Press the lock (B) and remove the fuel sender unit (D) from the fuel pump (C)."
    },
    {
      "type": "attention",
      "items": [
        "When removing the sender unit, do not deform the float arm or other parts."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "attention",
      "items": [
        "When installing the fuel sender unit, set it in place until it locks securely, and do not deform the float arm or other parts."
      ]
    }
  ],
