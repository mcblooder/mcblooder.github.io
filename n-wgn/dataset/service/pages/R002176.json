  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Rear Seat Cushion Trim Cover/Pad Removal/Removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Rear seat removal",
      "refs": [
        {
          "id": "R000799",
          "label": "Rear seat removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Remove rear seat cushion trim cover/pad"
    },
    {
      "type": "figure",
      "asset": "2176_3.0_jpn_11581396_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove pivot cover B (A)."
    },
    {
      "type": "figure",
      "asset": "2176_3.0_jpn_11581397_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the fasteners (B) and hooks (C) of the rear seat cushion trim cover (A)."
    },
    {
      "type": "figure",
      "asset": "2176_3.0_jpn_11581398_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the hook (A)."
    },
    {
      "type": "figure",
      "asset": "2176_3.0_jpn_11581399_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the hook (A)."
    },
    {
      "type": "figure",
      "asset": "2176_3.0_jpn_11581400_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Remove the fastener (A)."
    },
    {
      "type": "figure",
      "asset": "2176_3.0_jpn_11581401_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Remove the rear seat cushion trim cover/pad (A)."
    },
    {
      "type": "figure",
      "asset": "2176_3.0_jpn_11581402_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Flip up the rear seat back trim cover (A), remove the clip (B) on the inside of the cover, and separate the cover and pad."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "figure",
      "asset": "2176_3.0_jpn_11581403_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure. Replace the clip (A) of the rear seat cushion trim cover. Use seat handy pliers (B) (commercially available) for easier work."
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131120133233/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R002176_jpn/web/html/R002176_jpn_Content.html",
  "inOutline": true
}