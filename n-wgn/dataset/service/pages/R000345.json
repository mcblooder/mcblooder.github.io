  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Ignition timing check"
    },
    {
      "type": "attention",
      "items": [
        "After the engine is started and the radiator fan has run twice, the engine shall be warmed up for at least 2 minutes at 3,000 rpm with no load."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. HDS Connection"
    },
    {
      "type": "figure",
      "asset": "345_5.0_jpn_11583148_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect HDS to the data link coupler (A) on the left side of the driver's seat."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. DTC Confirmation"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Check DTC."
    },
    {
      "type": "attention",
      "items": [
        "If a DTC is displayed, the displayed fault diagnosis should be performed first."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Idling RPM Check",
      "refs": [
        {
          "id": "R000470",
          "label": "Idling RPM Check",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. SCS Short"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Turn ignition OFF (LOCK) mode. Execute SCS short in SCS mode of HDS."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Ignition timing Ignition timing"
    },
    {
      "type": "figure",
      "asset": "345_5.0_jpn_11583149_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Restart the engine and install the timing light in the service loop."
    },
    {
      "type": "figure",
      "asset": "345_5.0_jpn_11583150_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Point the timing light at the crankshaft pulley and check that the alignment mark (A) and ignition mark (B) (white marking) (white marking) are aligned when idling and rotating. If other than the standard value, if the PGM-FI ECU program is not up-to-date Update to the latest version If the program is up-to-date, Re-check with a new PGM-FI ECU. Turn ignition OFF (LOCK) mode. Remove HDS and timing lights.",
      "refs": [
        {
          "id": "R000447",
          "label": "Update to the latest version",
          "resolved": true
        },
        {
          "id": "R000448",
          "label": "Re-check with a new PGM-FI ECU.",
          "resolved": true
        }
      ]
    },
    {
      "type": "attention",
      "items": [
        "Confirmation shall be made from the specified viewing direction (C)."
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Ignition timing"
          }
        ],
        [
          {
            "text": "BTDC 0±2° at idle rpm (N or P position)"
          }
        ]
      ]
    }
  ],
