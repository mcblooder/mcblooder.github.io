    {
      "type": "paragraph",
      "text": "Cancellation of self-diagnostic mode"
    },
    {
      "type": "paragraph",
      "text": "To cancel the self-diagnostic mode, set the ignition to the ignition OFF (LOCK) mode."
    },
    {
      "type": "step",
      "number": "",
      "text": "1. Connect HDS to the data link coupler (16P) (A)."
    },
    {
      "type": "figure",
      "asset": "1410_5.0_jpn_11579602_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Turn ignition to ON mode."
    },
    {
      "type": "step",
      "number": "3",
      "text": "Check the DTC displayed on the HDS."
    },
    {
      "type": "paragraph",
      "text": "Refer to the instruction manual for the use of HDS."
    },
    {
      "type": "paragraph",
      "text": "Clear DTC"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Connect HDS to the data link coupler (16P) (A)."
    },
    {
      "type": "step",
      "number": "5",
      "text": "Turn ignition to ON mode."
    },
    {
      "type": "step",
      "number": "6",
      "text": "Clear DTC as instructed by HDS."
    },
    {
      "type": "paragraph",
      "text": "Refer to the instruction manual for the use of HDS."
    },
    {
      "type": "step",
      "number": "1",
      "text": "Turn ignition to ON mode."
    },
    {
      "type": "paragraph",
      "text": "Steps 2-5 should be done within 10 seconds"
    },
    {
      "type": "step",
      "number": "",
      "text": "2. Hold the passing switch in the ON position and turn the headlight switch (small) ON."
    },
    {
      "type": "figure",
      "asset": "1410_5.0_jpn_11579603_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Passing switch is turned OFF and ON and held."
    },
    {
      "type": "step",
      "number": "4",
      "text": "Turn the headlight switch (small) OFF and repeat ON/OFF twice more."
    },
    {
      "type": "step",
      "number": "5",
      "text": "Turn the passing switch OFF."
    },
    {
      "type": "step",
      "number": "",
      "text": "6. DTC is displayed on the information display in the combination meter."
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "If a DTC is displayed in the combination meter, confirm the failure diagnosis of the displayed DTC."
        },
        {
          "text": "Each time the Select/Reset knob is pressed, the next DTC is displayed."
        }
      ]
    },
