  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "A/C compressor Clutch removal and installation"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. A/C Compressor Clutch"
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11580993_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Compressor removal",
      "refs": [
        {
          "id": "R000880",
          "label": "Compressor removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Armature removal"
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11580994_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Secure the armature with the air conditioner clutch holder (A). Remove the center nut."
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11580995_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove armature (A) and shim (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Rotor pulley removal"
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11580996_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the snap ring (A) with snap ring pliers and remove the rotor pulley (B)."
    },
    {
      "type": "attention",
      "items": [
        "Do not damage the compressor body and rotor pulley."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Field Coil Removal"
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11580997_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove clamp (A) and disconnect connector (B). Remove the snap ring (C) with snap ring pliers and remove the field coil (D)."
    },
    {
      "type": "attention",
      "items": [
        "Do not damage the compressor body and field coil."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Field Coil Mounting"
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11580998_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install field coil (A) and attach snap ring (B) with snap ring pliers. Connect connector (C) and attach clamp (D)."
    },
    {
      "type": "attention",
      "items": [
        "Align the protrusion of the field coil with the hole in the compressor front plate.",
        "The snap ring shall be securely installed in the groove."
      ]
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Align the protrusion of the field coil with the hole in the compressor front plate."
        },
        {
          "text": "Align the protrusion of the field coil with the hole in the compressor front plate."
        },
        {
          "text": "The snap ring shall be securely installed in the groove."
        },
        {
          "text": "The snap ring shall be securely installed in the groove."
        }
      ]
    },
    {
      "type": "attention",
      "items": [
        "Field coil cords shall be securely attached with clamps to prevent contact with the rotor pulleys."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Rotor Pulley Mounting"
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11580999_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the rotor pulley (A) and attach the snap ring (B) with snap ring pliers."
    },
    {
      "type": "attention",
      "items": [
        "Do not force the rotor pulley into the machine while it is tilted.",
        "The snap ring shall be securely installed in the groove."
      ]
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Do not force the rotor pulley into the machine while it is tilted."
        },
        {
          "text": "Do not force the rotor pulley into the machine while it is tilted."
        },
        {
          "text": "The snap ring shall be securely installed in the groove."
        },
        {
          "text": "The snap ring shall be securely installed in the groove."
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Armature Mounting"
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11581000_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install shims (A) and armatures (B)."
    },
    {
      "type": "figure",
      "asset": "883_5.0_jpn_11581001_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Secure the armature with the air conditioner clutch holder (A) and tighten the center nut."
    },
    {
      "type": "attention",
      "items": [
        "Rotor Rotate the pulley by hand and it should turn smoothly without contacting the armature."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Compressor Installation",
      "refs": [
        {
          "id": "R000880",
          "label": "Compressor Installation",
          "resolved": true
        }
      ]
    }
  ],
