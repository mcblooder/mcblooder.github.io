  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Front door glass regulator removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Front door lining removal",
      "refs": [
        {
          "id": "R000720",
          "label": "Front door lining removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Front door hole seal removal"
    },
    {
      "type": "figure",
      "asset": "725_3.0_jpn_11337157_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the plug cap (A). Disconnect the coupler (B). Remove the harness clip (C). Remove the front door hole seal (D) as required. If the front door hall seal is damaged or torn, replace it with a new front door hall seal."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Front door glass regulator removal"
    },
    {
      "type": "figure",
      "asset": "725_3.0_jpn_11381308_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Move the front door glass regulator (A) so that the bolt is visible through the hole in the door panel. Remove the bolt and remove the front door glass (B) from the holder (C) of the front door glass regulator."
    },
    {
      "type": "figure",
      "asset": "725_3.0_jpn_11369314_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Raise the front door glass (A) and hold it with tape (B) to prevent it from falling. Disconnect the coupler (C). Remove the front door glass regulator (D)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Installation Precautions"
    },
    {
      "type": "figure",
      "asset": "725_3.0_jpn_11369315_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure. Apply grease to the sliding portion (B) of the front door glass regulator (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Front door glass alignment",
      "refs": [
        {
          "id": "R000741",
          "label": "Front door glass alignment",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Learning power window reset (driver's side)",
      "refs": [
        {
          "id": "R000916",
          "label": "Learning power window reset (driver's side)",
          "resolved": true
        }
      ]
    }
  ],
