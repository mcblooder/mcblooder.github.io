      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Front wiper motor Check"
    },
    {
      "type": "figure",
      "asset": "1011_3.0_jpn_11369876_2.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "1011_3.0_jpn_11037213_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A). Check that the front wiper motor (B) rotates smoothly and normally when battery voltage is applied between each terminal. Between No.1 and No.3 terminals Confirm that continuity is repeated during motor rotation. If there is a problem with the motor and it does not rotate smoothly Replace front wiper motor. Before installing the front wiper arm, operate the front wiper motor to the automatic stop position. Connect the coupler.",
      "refs": [
        {
          "id": "R001013",
          "label": "Replace front wiper motor.",
          "resolved": true
        }
      ]
    },
    {
      "type": "attention",
      "items": [
        "When applying battery voltage, be very careful not to short-circuit the battery.",
        "Use an analog tester."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
