    },
    {
      "type": "step",
      "number": "4",
      "text": "Set the dynamic damper weight at the specified dimension (A). Std. 455－461mm"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Dynamic damper band installation"
    },
