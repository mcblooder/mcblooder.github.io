  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Front door glass removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Front door molding removal",
      "refs": [
        {
          "id": "R000728",
          "label": "Front door molding removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Front door lining removal",
      "refs": [
        {
          "id": "R000720",
          "label": "Front door lining removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Front door hole seal removal"
    },
    {
      "type": "figure",
      "asset": "724_3.0_jpn_11337156_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the plug cap (A). Disconnect the coupler (B). Remove the harness clip (C). Remove the front door hole seal (D) as required. If the front door hall seal is damaged or torn, replace it with a new front door hall seal."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Front door glass removal"
    },
    {
      "type": "figure",
      "asset": "724_3.0_jpn_11369299_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Move the front door glass regulator (A) so that the bolt is visible through the hole in the door panel. Remove the bolt and remove the front door glass (B) from the holder (C) of the front door glass regulator."
    },
    {
      "type": "attention",
      "items": [
        "Front Door Be careful not to let the glass fall inside the door."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Front door glass run channel removal"
    },
    {
      "type": "figure",
      "asset": "724_3.0_jpn_11369302_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the glass run channel (A) from the front door sash."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Front door front lower sash removal"
    },
    {
      "type": "figure",
      "asset": "724_3.0_jpn_11381309_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the front door front lower sash (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Front door glass alignment",
      "refs": [
        {
          "id": "R000741",
          "label": "Front door glass alignment",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Power window reset and learn (driver's side)",
      "refs": [
        {
          "id": "R000916",
          "label": "Power window reset and learn (driver's side)",
          "resolved": true
        }
      ]
    }
