    {
      "type": "heading",
      "level": 3,
      "text": "1. Front wiper blade removal"
    },
    {
      "type": "figure",
      "asset": "1018_3.0_jpn_11589050_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Release the lock (B) on the front wiper blade (A) and slide it off the front wiper arm (C)."
    },
    {
      "type": "figure",
      "asset": "1018_3.0_jpn_11580886_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Pull the rubber (A) out of the front wiper blade (B)."
    },
    {
      "type": "figure",
      "asset": "1018_3.0_jpn_11580887_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the retainer (A) from the rubber (B)."
    },
    {
      "type": "paragraph",
      "text": "After installation, check that the front wiper arm operates smoothly."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Front wiper blade installation"
    },
    {
      "type": "figure",
      "asset": "1018_3.0_jpn_11580888_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Attach retainer (A) to rubber (B)."
    },
    {
      "type": "figure",
      "asset": "1018_3.0_jpn_11580889_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Attach the rubber (A) to the front wiper blade (B)."
    },
    {
      "type": "figure",
      "asset": "1018_3.0_jpn_11589051_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Attach the front wiper blade (A) to the front wiper arm (B)."
    }
  ],
