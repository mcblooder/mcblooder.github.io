  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "DTC Explanation: P0299"
    },
    {
      "type": "dtc",
      "code": "P0299",
      "text": "DTC P0299: Insufficient turbocharger boost pressure"
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Detection principle explanation"
    },
    {
      "type": "figure",
      "asset": "31_3.0_jpn_11259986_2.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "31_3.0_jpn_11033536_4.0_disp.png"
    },
    {
      "type": "paragraph",
      "text": "The turbocharger system is controlled for boost pressure by the PGM-FI ECU. if the actual boost pressure remains below the specified value for more than a specified period of time in a region where the PGM-FI ECU can determine that sufficient boost pressure is generated, the PGM-FI ECU determines a failure and stores DTC."
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Detection frequency, detection sequence, detection time required, detection method type, OBD status"
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Detection frequency"
          },
          {
            "text": "Once during D/C"
          }
        ],
        [
          {
            "text": "Detection order (of the DTC in question)"
          },
          {
            "text": "nashi (Pyrus pyrifolia, esp. var. culta)"
          }
        ],
        [
          {
            "text": "Detection time"
          },
          {
            "text": "More than 7.5 seconds"
          }
        ],
        [
          {
            "text": "Detection method type"
          },
          {
            "text": "2D/C (2 consecutive detection method), PGM-FI warning light: On"
          }
        ],
        [
          {
            "text": "OBD Status"
          },
          {
            "text": "Normal judgment, failure judgment, not completed"
          }
        ]
      ]
    },
