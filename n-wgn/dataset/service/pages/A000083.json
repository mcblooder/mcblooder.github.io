    {
      "type": "heading",
      "level": 2,
      "text": "Failure Criteria"
    },
    {
      "type": "paragraph",
      "text": "When one of the following conditions continues for more than 5 seconds"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "When the PGM-FI ECU cannot receive signals from the DC-DC converter sent using LIN."
        },
        {
          "text": "When the PGM-FI ECU receives an error signal from the DC-DC converter sent using LIN."
        }
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Estimated Failure Site"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Disconnection of cord (LIN line) between PGM-FI ECU and DC-DC converter"
        },
        {
          "text": "Ground fault in cord (LIN line) between PGM-FI ECU and DC-DC converter"
        },
        {
          "text": "DC-DC converter failure"
        },
        {
          "text": "PGM-FI ECU internal circuit failure"
        }
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Store and clear DTC"
    },
    {
      "type": "paragraph",
      "text": "If the vehicle is determined to be faulty, the temporary DTC, DTC and freeze data are stored in the PGM-FI ECU memory without the PGM-FI warning light being turned on."
    },
    {
      "type": "paragraph",
      "text": "Temporary DTCs, DTCs and freeze data are cleared by using the clear command of the scan tool (including HDS) or by removing the 12V battery terminal."
    }
  ],
