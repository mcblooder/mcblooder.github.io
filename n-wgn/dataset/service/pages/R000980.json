  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Side turn signal light/valve removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Side turn signal light removal"
    },
    {
      "type": "figure",
      "asset": "980_3.0_jpn_11037128_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Push the retaining spring (B) from the notch (front side of the vehicle) of the side turn signal light (A) and remove the side turn signal light. Protect the fender with a rag to prevent scratching. Disconnect the coupler (C) and remove the side turn signal light."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Valve removal"
    },
    {
      "type": "figure",
      "asset": "980_3.0_jpn_11037129_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the socket (A) by rotating it counterclockwise and remove the valve (B). Side turn signal light: 12V-5W"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
