  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Drum Brake Shoe Removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Drum Brake Development"
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035924_3.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Lift Set",
      "refs": [
        {
          "id": "G000319",
          "label": "Lift Set",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Rear wheel removal",
      "refs": [
        {
          "id": "R000659",
          "label": "Rear wheel removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Parking brake release"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Brake drum removal",
      "refs": [
        {
          "id": "R000695",
          "label": "Brake drum removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Shoe Clamp Spring Removal"
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035925_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "While pressing the shoe clamp spring (A), rotate the tension pin (B) to remove the shoe clamp spring."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Brake shoe separation"
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035926_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Slide the brake shoe (C) down and remove the brake spring B. Remove the connecting rod (D). Remove brake spring A. Remove the adjuster lever (E). Remove the adjuster spring (F). Separate the brake shoes. Disconnect the parking brake cable from the parking brake lever (G)."
    },
    {
      "type": "attention",
      "items": [
        "Be careful not to scratch the wheel cylinder dust cover."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Parking brake lever removal"
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035927_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the U-clip (A). Remove the wave washer (B). Remove the parking brake lever (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Parking brake lever installation"
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035928_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Attach the parking brake lever (B) to the brake shoe (A) with the wave washer (C) and parking brake lever pin (D) and secure with a new U-clip (E). The U-clip should be securely bent and fastened. Connect the parking brake cable to the parking brake lever."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Brake shoe assembly"
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035929_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Apply grease to the sliding parts of each component before assembling the brake shoe. The figure is a reference drawing showing the grease application points after the brake shoes are installed."
    },
    {
      "type": "attention",
      "items": [
        "Do not allow grease, oil, fat, etc. to adhere to the surface of the brake lining."
      ]
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035930_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Install the adjuster lever (B) onto the brake shoe (C). Clean the adjuster bolts (D) and connecting rods (E) and (F), and apply cosmo rubber grease evenly to the threads of the adjuster bolts. Install the connecting rod on the adjuster bolt. Assemble brake spring A and connecting rod and install in brake shoe. Install the adjuster spring (G) onto the adjuster lever and brake shoe. Install the brake spring A in the correct direction."
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035931_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Apply grease to each sliding part of the brake shoe (A). The figure is a reference drawing showing the grease application points after the brake shoes are installed. Install the brake shoes. Install brake springs B on both ends of the lower side of the brake shoe."
    },
    {
      "type": "attention",
      "items": [
        "Do not allow grease, oil, fat, etc. to adhere to the surface of the brake lining."
      ]
    },
    {
      "type": "attention",
      "items": [
        "Be careful not to scratch the wheel cylinder dust cover."
      ]
    },
    {
      "type": "figure",
      "asset": "697_3.0_jpn_11035932_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "10",
      "text": "Fix the shoe with the shoe clamp spring (A) and tension pin (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Brake drum installation",
      "refs": [
        {
          "id": "R000695",
          "label": "Brake drum installation",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Rear wheel mounting",
      "refs": [
        {
          "id": "R000659",
          "label": "Rear wheel mounting",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. air venting"
    },
    {
      "type": "step",
      "number": "1",
      "text": "If the wheel cylinder has been removed, Air venting.",
      "refs": [
        {
          "id": "R000685",
          "label": "Air venting.",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Parking brake adjustment",
      "refs": [
        {
          "id": "R000684",
          "label": "Parking brake adjustment",
          "resolved": true
        }
      ]
    }
  ],
