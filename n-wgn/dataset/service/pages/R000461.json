    {
      "type": "heading",
      "level": 3,
      "text": "5. HDS Connection"
    },
    {
      "type": "figure",
      "asset": "461_3.0_jpn_11291970_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect HDS to the data link coupler (A) on the left side of the driver's seat."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Carbon Deposition Correction Value Clear"
    },
    {
      "type": "step",
      "number": "1",
      "text": "In HDS, select the DBW test in the Inspection menu, then select Clear Throttle Valve Correction Value to clear the carbon deposit correction value. Turn ignition OFF (LOCK) mode. Turn ignition to ON mode and wait for 2 seconds."
    },
    {
      "type": "attention",
      "items": [
        "Do not step on the accelerator pedal at this time."
      ]
    },
