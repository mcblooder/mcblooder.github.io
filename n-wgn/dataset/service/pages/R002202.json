    {
      "type": "figure",
      "asset": "2202_3.0_jpn_11390223_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove cable clamp (A) and disconnect cable (B)."
    },
    {
      "type": "figure",
      "asset": "2202_3.0_jpn_11337278_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the bolts (A, B) and separate the rear seat back frame (C) and rear seat cushion frame (D)."
