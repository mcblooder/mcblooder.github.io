      "type": "figure",
      "asset": "2202_3.0_jpn_11337280_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "If necessary, remove the nylon bushing (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
