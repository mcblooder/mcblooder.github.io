          },
          {
            "text": "+0.012－+0.015mm"
          }
        ]
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Conrod bearing center wall thickness dimension:"
          },
          {
            "text": "1.5mm"
          }
        ]
      ]
    },
    {
      "type": "attention",
      "items": [
        "Always measure and confirm the oil clearance, not just using this mating chart."
      ]
    },
    {
