  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Headlight Leveling Sensor Removal and Installation"
    },
    {
      "type": "attention",
      "items": [
        "Garage jacks, rigid racks, and lifts should be securely applied in place."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Vehicle Lift Up",
      "refs": [
        {
          "id": "G000319",
          "label": "Vehicle Lift Up",
          "resolved": true
        }
      ]
    },
    {
      "type": "step",
      "number": "1",
      "text": "Jack up the rear wheels with wheel stoppers on the front wheels and support with rigid racks. Or, lift up the vehicle."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Headlight leveling sensor removal"
    },
    {
      "type": "figure",
      "asset": "989_3.0_jpn_11400249_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A). Remove the headlight leveling sensor (B)."
    },
    {
      "type": "attention",
      "items": [
        "The linkage (C) shall not be disassembled."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Headlight initial position learning",
      "refs": [
        {
          "id": "R000915",
          "label": "Headlight initial position learning",
          "resolved": true
        }
      ]
    }
  ],
