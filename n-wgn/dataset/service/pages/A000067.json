    {
      "type": "heading",
      "level": 2,
      "text": "Failure Criteria"
    },
    {
      "type": "paragraph",
      "text": "ELD output voltage remains below 0.27V for more than 5.0 seconds."
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Estimated Failure Site"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Ground fault in code between PGM-FI ECU and ELD (ELD line)"
        },
        {
          "text": "Disconnection of ELD cord (power supply line)"
        },
        {
          "text": "ELD failure"
        },
        {
          "text": "PGM-FI ECU internal circuit failure"
        }
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Store and clear DTC"
    },
    {
      "type": "paragraph",
      "text": "If the vehicle is determined to have a fault, a temporary DTC is stored in the PGM-FI ECU memory. If the same failure is detected at the next D/C (two consecutive detections), the DTC and freeze data are stored without turning on the PGM-FI warning light."
    },
    {
      "type": "paragraph",
      "text": "Temporary DTCs, DTCs and freeze data are cleared by using the clear command of the scan tool (including HDS) or by removing the 12V battery terminal."
    }
  ],
