  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Inspect the discharge rate of the fuel pump."
    },
    {
      "type": "attention",
      "items": [
        "Fire is strictly prohibited."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. HDS Connection"
    },
    {
      "type": "figure",
      "asset": "479_3.0_jpn_11291993_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect HDS to the data link coupler (A) on the left side of the driver's seat."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Fuel pressure Removal",
      "refs": [
        {
          "id": "R000474",
          "label": "Fuel pressure Removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Fuel Hose Installation"
    },
    {
      "type": "figure",
      "asset": "479_3.0_jpn_11291994_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect the hose to the fuel pipe (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Discharge volume Inspection"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Select Fuel Pump Force Activation in the HDS inspection menu to activate the fuel pump. Check for discharge. If there is discharge, stop the fuel pump forced operation, scrap the discharged fuel, select the fuel pump forced operation again, and measure the discharge for 10 seconds."
    },
    {
      "type": "attention",
      "items": [
        "Measure under no-load conditions with no headlights, blower motor, rear defroster, radiator fan, A/C, etc. in operation."
      ]
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Cars not equipped with a turbo charger",
            "colspan": 2
          }
        ],
        [
          {
            "text": ""
          },
          {
            "text": "111mL or more/10 sec."
          }
        ],
        [
          {
            "text": "Turbo Charger equipped vehicle",
            "colspan": 2
          }
        ],
        [
          {
            "text": ""
          },
          {
            "text": "150mL or more/10 sec."
          }
        ]
      ]
    },
    {
