  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Disassembly and assembly of CVT transmission"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Oil pan removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582326_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the oil pan (A) and oil pan gasket (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Transmission fluid strainer removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582327_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the transmission fluid strainer (A). Remove the O-ring (B). Inspect the transmission fluid strainer.",
      "refs": [
        {
          "id": "R000576",
          "label": "Inspect the transmission fluid strainer.",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Valve body assembly removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582328_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582329_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the oil guide plate (A). Remove the valve body assembly (B)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582330_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Remove the knock pin (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Solenoid Wire Harness Removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11676653_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the solenoid wire harness (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Transmission fluid filter removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582332_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the circlip (A)."
    },
    {
      "type": "attention",
      "items": [
        "If debris cannot be removed, replace the transmission fluid filter."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Driven pulley oil pressure sensor removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582333_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the driven pulley oil pressure sensor (A) and sealing washer (B)."
    },
    {
      "type": "attention",
      "items": [
        "Be careful not to damage the plastic part of the sensor."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Remove level gauge, filler cap, and breather cap"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582334_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the level gauge (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. L. Side cover removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582335_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "L. Remove side cover A."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Drive pulley speed sensor, driven pulley speed sensor, torque converter turbine speed sensor Remove"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582336_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the drive pulley speed sensor (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Control lever removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582337_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Caulk the lock washer (A). Remove the mounting bolt (B) and lock washer."
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the control lever (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "11. Shift position sensor removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582338_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the control shaft cover (A) and remove the shift position sensor (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. Transmission Hanger Removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582339_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "13. Torque converter case removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582340_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Place the torque converter case side of the transmission on top."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "14. Oil funnel plate removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582341_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "15. Stator shaft removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582342_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the stator shaft (A). Remove the sealing ring (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "16. Oil pass Body removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582343_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the oil pass body (A). Remove the knock pin (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "17. Remove input shaft assembly."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582344_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the sealing ring (A). Remove the input shaft assembly (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "18. Oil pump body removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582345_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the oil pump body mounting bolt (A), and remove the oil pump body (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "19. Reverse idler gear removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582346_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the reverse idler gear shaft (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "20. Reverse clutch assembly removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582347_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the sealing ring (A). Remove the snap ring (B). Remove the cotter retainer (C) and cotter (D). Remove the forward driven gear (E). Remove the thrust needle bearing (F). Remove the reverse driven gear (G). Remove the needle bearing (H). Remove the thrust needle bearing (I). Remove the reverse clutch assembly (K). Remove the O-ring (L)."
    },
    {
      "type": "step",
      "number": "9",
      "text": "Remove the reverse gear collar (J)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "21. Driven pulley shaft bearing removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582348_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Transmission is placed in the P position. Tie down the transmission case to the workbench with the crossed tie-down belts."
    },
    {
      "type": "attention",
      "items": [
        "The transmission case shall be securely fastened to the workbench due to the high tightening torque of the lock nut."
      ]
    },
    {
      "type": "attention",
      "items": [
        "When securing the transmission case to the workbench, stabilize the transmission case with a piece of wood (A) or similar."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582349_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Use a tug (A) or similar tool to cut up the caulk (C) of the locknut (B)."
    },
    {
      "type": "attention",
      "items": [
        "When caulking up the lock nut, be careful not to let any chirico, etc., get inside the transmission.",
        "Caulk the locknut sufficiently and remove it carefully so as not to damage the shaft."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582350_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove locknut (A)."
    },
    {
      "type": "attention",
      "items": [
        "Never use an impact wrench."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582351_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Use the bearing puller (A) to remove the spline washer (B) and driven pulley shaft bearing (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "22. Differential assembly removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582352_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the differential assembly (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "23. Final drive gear removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582353_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the final drive gear (B) using the bearing puller (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "24. Input shaft holder removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582354_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the input shaft holder (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "25. Control shaft removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582355_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Unhook the detent arm spring (A)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582356_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Caulk the lock washer (A). Remove the mounting bolt (B) and lock washer."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582357_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the roller (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "26. Parking brake pole removal"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582358_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Caulk the parking brake rod guide (A). Remove the parking brake rod guide."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582359_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Unhook the parking brake pole spring (A)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582360_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Remove the parking brake pole spring (A) and parking brake pole shaft (B)."
    },
    {
      "type": "attention",
      "items": [
        "HMMF shall be applied to O-rings and sliding parts."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Parking brake pole installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582361_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the parking brake pole (A)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582362_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Install the hook of the parking brake pole spring (A)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582363_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Install the parking brake rod holder (A). Install new parking brake rod guide (B). Caulk the parking brake rod guide."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Control Shaft Mounting"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582364_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the detent arm spring (A) and detent arm (B), and attach the control shaft (C)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582365_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Install the new lock washer (A) and tighten the detent arm mounting bolt (B). Crimp the lock washer."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582366_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Install the hook of the detent arm spring (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Input shaft holder mounting"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582367_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the lubrication pipe (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Final drive gear installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582368_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Stabilize the transmission case (A) by placing a piece of wood (B) or similar object against the underside of the transmission case (A)."
    },
    {
      "type": "attention",
      "items": [
        "A piece of wood or other object should always be placed against the underside of the driven pulley shaft (C)."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582369_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Install the final drive gear (A) in the orientation shown in the figure by lightly tapping it with the inner driver handle 40 and inner bearing driver attachment 30."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Differential Assy. installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582370_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the baffle plate (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Driven Pulley Shaft Bearing Mounting"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582371_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Stabilize the transmission case (A) by placing a piece of wood (B) or similar object against the underside of the transmission case (A)."
    },
    {
      "type": "attention",
      "items": [
        "A piece of wood or other object should always be placed against the underside of the driven pulley shaft (C)."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582372_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Install the new bearing (A) by lightly tapping it using an oil seal driver 41.8."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582373_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Transmission is placed in the P position. Tie down the transmission case to the workbench with the crossed tie-down belts."
    },
    {
      "type": "attention",
      "items": [
        "The transmission case shall be securely fastened to the workbench due to the high tightening torque of the lock nut."
      ]
    },
    {
      "type": "attention",
      "items": [
        "When securing the transmission case to the workbench, stabilize the transmission case with a piece of wood (A) or similar."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582374_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Install the new spline washer (A) with the mark (B) facing up on the driven pulley shaft (C), tighten the new locknut (D) and press-fit the spline washer onto the driven pulley shaft."
    },
    {
      "type": "attention",
      "items": [
        "Never use an impact wrench."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582375_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Caulk the lock nut securely into the recess on the driven pulley shaft. Caulk to a depth of at least 0.7 mm (B) using a punch with a tip diameter of 3.0-3.5 mm (A). Ensure that there are no cracks or other damage to the caulking area."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Reverse Clutch Assy. installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582376_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new O-ring (A)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582377_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "12",
      "text": "Check that the snap ring is securely attached, and inspect that the snap ring mounting outer diameter dimension (A) is 38.7 mm or less."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582378_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "13",
      "text": "Install a new sealing ring (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Reverse idler gear installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582379_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install thrust washer (A). Install reverse idler gear (B). Install needle bearing (C). Install the reverse idler gear shaft (D)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Oil Pump Body Installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582380_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new O-ring (B) on the 24 x 10 mm oil pipe (A). Install 24 x 10 mm oil pipe. Install a new O-ring (D) on the 21 x 10 mm oil pipe (C). Install 21 x 10 mm oil pipe. Install the knock pin (E). Install the oil pump body (F)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Input shaft assembly."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582381_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the input shaft assembly (A). Install a new sealing ring (B). Adjust thrust clearance.",
      "refs": [
        {
          "id": "R000587",
          "label": "Adjust thrust clearance.",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "11. Oil pass Body installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582382_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the knock pin (A). Install the oil pass body (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. Stator shaft mounting"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582383_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new sealing ring (A). Install the stator shaft (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "13. Oil funnel plate installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582384_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "14. Torque converter case mounting"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582385_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new O-ring (A) on each oil pipe. Install 10.9 x 29 mm pipe (B). Install 10.9 x 48 mm pipe (C). Install 10.9 x 64 mm pipe (D). Install 8 x 43 mm pipe (E). Install the knock pin (F)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582386_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Remove old fluid packings, oil and dirt from transmission case, torque converter case, bolts and bolt holes. Apply Honda Genuine Liquid Packing 5460H to the transmission case. Transmission Apply liquid packing along the dashed line (A) 1 mm from the inside chamfer of the case with a line diameter of about 1.5 mm (1 mm-2 mm)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582387_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "9",
      "text": "Install the torque converter case and tighten the mounting bolts two to three times. Place the torque converter case side of the transmission down."
    },
    {
      "type": "attention",
      "items": [
        "If the liquid packing is left on for more than 4 minutes after application, do not install it as it is. Remove the packing once and reapply.",
        "Oil should be injected at least one hour after installation.",
        "Do not touch the liquid packing-applied surface.",
        "The engine should be started at least 3 hours after installation.",
        "Note that sliding the case during installation may result in uneven liquid packing and cause oil leaks, etc."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "15. Transmission Hanger Installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582388_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "16. Shift Position Sensor Installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582389_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Turn the control shaft to put the transmission in the N position."
    },
    {
      "type": "attention",
      "items": [
        "Work shall be performed so as not to scratch the control shaft flat surface (A)."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582390_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Adjust the shift position sensor (A) to the N position. Align the notch (B) in the rotating frame with the reference notch (C) and insert a 2.0 mm thick Thickness Gauge (D) to fix the N position."
    },
    {
      "type": "attention",
      "items": [
        "Be sure to use 2.0 mm thick Thickness Gauges or equivalent."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582391_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "While holding the shift position sensor (B) in the N position with the sickness gauge (A), align the shift position sensor (B) with the control shaft and gently install it."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582392_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "While keeping the N position fixed, tighten the mounting bolts to the specified torque. Remove the sickness gauge (A)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582393_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Install the control shaft cover (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "17. Control Lever Mounting"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582394_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the control lever (A). Install the new lock washer (B) and install the mounting bolt (C)."
    },
    {
      "type": "step",
      "number": "3",
      "text": "Crimp the lock washer."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "18. Drive pulley speed sensor, driven pulley speed sensor, torque converter Turbine speed sensor Mounting"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582395_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new O-ring (A) on each sensor."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "19. L. Side cover installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582396_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new O-ring (D) on the 10.9 x 22 mm pipe (C). Install 10.9 x 22mm pipe."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "20. Level Gauge, Filler Cap, Breather Cap Installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11679503_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the level gauge (A)."
    },
    {
      "type": "attention",
      "items": [
        "The filler cap must be installed with the \"FRONT\" mark (arrow) facing the front of the vehicle."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "21. Driven pulley oil pressure sensor Installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582398_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the driven pulley oil pressure sensor (B) using a new sealing washer (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "22. Transmission Fluid Filter Installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582399_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new O-ring (A)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582400_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Check that the circlip is securely attached and that the circlip end gap (A) is 4.4 mm or more."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "23. Solenoid Wire Harness Installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11676654_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new O-ring (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "24. Valve body assembly. installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582402_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Transmission is placed in the P position. Install a new O-ring (A) on each oil pipe. Install 10.9 x 48 mm pipe (B). Install 8 x 56.5 mm pipe (C). Install 10.9 x 112 mm pipe (D). Install the knock pin (E)."
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582403_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Align the control lever pin (A) on the control shaft with the manual valve guide (B) and install the valve body assembly (C)."
    },
    {
      "type": "attention",
      "items": [
        "Transmission should be worked in P position."
      ]
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582404_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "10",
      "text": "Install the transmission fluid temperature sensor (A). Install the ground terminal (B). Connect the coupler (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "25. Transmission Fluid Strainer Installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582405_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new O-ring (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "26. Oil pan installation"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582406_5.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "572_5.0_jpn_11582407_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Clean and install the oil magnet (A). Temporarily tighten the new oil pan gasket (C) and oil pan (D) with the mounting bolts (E) to the extent that they are tight against the transmission case. Tighten the mounting bolts diagonally with the specified torque. Re-tighten the mounting bolts diagonally with the specified torque."
    },
    {
      "type": "attention",
      "items": [
        "When installing the oil magnet, it must be installed in the specified position (B)."
      ]
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131205174356/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R000572_jpn/web/html/R000572_jpn_Content.html",
  "inOutline": true
}