  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Rear door outer handle removal"
    },
    {
      "type": "paragraph",
      "text": "Glass should be raised."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Rear door lining removal",
      "refs": [
        {
          "id": "R000731",
          "label": "Rear door lining removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Rear door hole seal removal"
    },
    {
      "type": "figure",
      "asset": "732_3.0_jpn_11581100_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the plug cap (A). Disconnect the coupler (B). Remove the harness clip (C). Remove the rear door hole seal (D) as required. If the rear door hall seal is damaged or torn, replace it with a new rear door hall seal."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Rear door outer handle removal"
    },
    {
      "type": "figure",
      "asset": "732_3.0_jpn_11581101_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Turn and remove the joint bushing (A) and use the clip remover to disconnect the outer handle rod (B)."
    },
    {
      "type": "figure",
      "asset": "732_3.0_jpn_11581102_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the rear door outer handle bracket (A)."
    },
    {
      "type": "figure",
      "asset": "732_3.0_jpn_11581103_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "While pulling the rear door outer handle (A), remove it from the hole in the door panel as shown."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Joint bushing removal"
    },
    {
      "type": "figure",
      "asset": "732_3.0_jpn_11581104_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the joint bushing (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
