  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Rear door lining removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Rear door quarter inner garnish removal"
    },
    {
      "type": "figure",
      "asset": "731_3.0_jpn_11337161_4.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Rear door lining removal"
    },
    {
      "type": "figure",
      "asset": "731_3.0_jpn_11364941_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the screws (A and B)."
    },
    {
      "type": "figure",
      "asset": "731_3.0_jpn_11381311_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Insert the handy remover into the gap on the underside of the rear door lining (A), pull the rear door lining toward you, and remove the clip. Slide the rear door lining upward and remove it."
    },
    {
      "type": "figure",
      "asset": "731_3.0_jpn_11364943_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Disconnect the coupler (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Rear door inner weather strip removal"
    },
    {
      "type": "figure",
      "asset": "731_3.0_jpn_11364944_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Pull out and remove the rear door inner weather strip (A) from the rear side."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Rear door power window switch panel removal"
    },
    {
      "type": "figure",
      "asset": "731_3.0_jpn_11364945_2.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Rear door inner handle garnish removal"
    },
    {
      "type": "figure",
      "asset": "731_3.0_jpn_11364946_2.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
