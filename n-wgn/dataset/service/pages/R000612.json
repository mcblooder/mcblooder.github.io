  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Rear Drive Shaft Removal and Installation"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Lift Set",
      "refs": [
        {
          "id": "G000319",
          "label": "Lift Set",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Rear wheel removal",
      "refs": [
        {
          "id": "R000659",
          "label": "Rear wheel removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Exhaust pipe/silencer removal",
      "refs": [
        {
          "id": "R000416",
          "label": "Exhaust pipe/silencer removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Spindle nut removal"
    },
    {
      "type": "figure",
      "asset": "612_3.0_jpn_11035434_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Raise the caulk (A) and remove the spindle nut (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Rear differential removal",
      "refs": [
        {
          "id": "R000622",
          "label": "Rear differential removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Rear drive shaft outboard joint removal"
    },
    {
      "type": "figure",
      "asset": "612_3.0_jpn_11350546_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Tap the end of the rear driveshaft with a plastic hammer and press the outboard joint into the inside of the rear hub."
    },
    {
      "type": "figure",
      "asset": "612_3.0_jpn_11350547_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the rear drive shaft (A)."
    },
    {
      "type": "attention",
      "items": [
        "Be careful not to damage the wheel sensor (B).",
        "Be careful not to pull the roller out of the joint by holding the shaft part. If the roller is pulled out, remove the boot and reassemble the joint."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Set Ring Removal"
    },
    {
      "type": "figure",
      "asset": "612_3.0_jpn_11035438_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the set ring (B) from the inboard joint (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "attention",
      "items": [
        "Wheel Care should be taken not to damage the sensor.",
        "Be very careful to prevent dust and other debris from entering the transmission.",
        "Set rings shall be new at the time of replacement."
      ]
    }
  ],
