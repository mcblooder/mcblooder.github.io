      "items": [
        {
          "text": "Combination Meter Self-Diagnosis do",
          "refs": [
            {
              "id": "T001427",
              "label": "Combination Meter Self-Diagnosis",
              "resolved": true
            }
          ]
        },
        {
          "text": "In the HDS body electrical menu, check the F-CAN communication line between the PGM-FI ECU and the combination meter for any abnormalities."
        },
        {
          "text": "Check for broken or shorted cords between shift position sensor and PGM-FI ECU"
        },
        {
          "text": "Inspect shift position sensor. do",
          "refs": [
            {
              "id": "R000557",
              "label": "Inspect shift position sensor.",
              "resolved": true
            }
          ]
        }
      ]
    },
    {
      "type": "paragraph",
      "text": "probable cause"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Defective combination meter"
        },
        {
          "text": "Disconnection or short circuit of the F-CAN communication line between the PGM-FI ECU and the combination meter"
        },
        {
          "text": "Disconnection or short circuit of the cord between the shift position sensor and the PGM-FI ECU"
        },
        {
          "text": "Defective shift position sensor"
        }
      ]
