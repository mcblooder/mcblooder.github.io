  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Inspect and adjust parking brake."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Parking brake pedal position Check"
    },
    {
      "type": "figure",
      "asset": "684_3.0_jpn_11035835_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Depress the parking brake pedal (A) with a force of 294 N (30 kgf). Inspect the number of notches when the pedal locks."
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Pedal travel: 1.5"
          },
          {
            "text": "5-7 Notch"
          }
        ]
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Parking brake Pedal pressure Result of inspection"
    },
    {
      "type": "step",
      "number": "1",
      "text": "If the inspection shows that the number of notches is outside the specified number of notches, Inspect the lining thickness of the rear brakes. If the lining thickness is within the standard value, adjust the parking brake pedal travel.",
      "refs": [
        {
          "id": "R000696",
          "label": "Inspect the lining thickness of the rear brakes.",
          "resolved": true
        }
      ]
    },
    {
      "type": "paragraph",
      "text": "If the rear brake shoes have been removed for other work, etc., after installation, depress the brake pedal hard several times before making adjustments."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Lift Set",
      "refs": [
        {
          "id": "G000319",
          "label": "Lift Set",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Parking brake release"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Equalizer cover removal"
    },
    {
      "type": "figure",
      "asset": "684_3.0_jpn_11035836_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Turn up the carpet in the center of the floor. Remove the equalizer cover (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Adjust Nut Loosen"
    },
    {
      "type": "figure",
      "asset": "684_3.0_jpn_11035837_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Loosen the adjusting nut (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Parking brake pedal adjustment"
    },
    {
      "type": "figure",
      "asset": "684_3.0_jpn_11035838_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Press the parking brake pedal one notch. Tighten the adjusting nut to the point where the rear wheel lightly hooks and turns. Return the parking brake and turn the rear wheel to make sure there is no drag."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. Parking brake pedal position Check"
    },
    {
      "type": "figure",
      "asset": "684_3.0_jpn_11035839_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Depress the parking brake pedal (A) with a force of 294 N (30 kgf). Inspect the number of notches when the pedal locks."
    },
    {
      "type": "table",
      "rows": [
        [
          {
            "text": "Pedal travel: 1.5"
          },
          {
            "text": "5-7 Notch"
          }
        ]
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Equalizer cover installation"
    },
    {
      "type": "figure",
      "asset": "684_3.0_jpn_11035840_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the equalizer cover (A). Restore the carpet in the center of the floor."
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131015114331/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R000684_jpn/web/html/R000684_jpn_Content.html",
