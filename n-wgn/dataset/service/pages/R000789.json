      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Remove both front pillar garnishes."
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Side curtains Non-equipped vehicles without airbags",
          "refs": [
