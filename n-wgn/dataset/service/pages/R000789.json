        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "11. Select Lever Control Wire Disconnect",
      "refs": [
        {
          "id": "R000553",
          "label": "Select Lever Control Wire Disconnect",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. Heater Duct removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "13. Instrument panel/steering hanger beam removal (driver's side)"
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581284_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler and remove the coupler clip (B) from the fuse box (A) and its surroundings."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11589048_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the harness clip (A). Remove the brake pedal support stay (B)."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11589049_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the bolts (A, B). Disconnect the coupler (C)."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581287_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Disconnect the air hose (A)."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581288_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Disconnect the coupler (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "14. Instrument panel/steering hanger beam removal (passenger side)"
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581289_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the cover (A). Disconnect the coupler (B). Remove the harness clip (C)."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581291_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Disconnect the coupler (A). Remove harness clip (B) and ground bolt (C)."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581293_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Disconnect the coupler (A)."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581296_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Disconnect the coupler (A) and harness clip (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "15. Remove instrument panel/steering hanger beam (engine compartment side)"
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581297_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the cap (A) and remove the steering hanger beam mounting bolt."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "16. Remove instrument panel/steering hanger beam"
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581300_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the bolt from the passenger side."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581301_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the bolt from the driver's side."
    },
    {
      "type": "figure",
      "asset": "789_3.0_jpn_11581302_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Slightly lift up the instrument panel/steering hanger beam (A) and pull it toward you to remove it from the guide pins (B and C) on the body, then remove the instrument panel/steering hanger beam from the front door opening to the outside."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "17. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
