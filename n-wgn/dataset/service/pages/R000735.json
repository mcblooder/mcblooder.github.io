  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Rear door glass regulator removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Rear door lining removal",
      "refs": [
        {
          "id": "R000731",
          "label": "Rear door lining removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Rear door hole seal removal"
    },
    {
      "type": "figure",
      "asset": "735_3.0_jpn_11581119_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the plug cap (A). Disconnect the coupler (B). Remove the harness clip (C). Remove the rear door hole seal (D) as required. If the rear door hall seal is damaged or torn, replace it with a new rear door hall seal."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Rear door glass regulator removal"
    },
    {
      "type": "figure",
      "asset": "735_3.0_jpn_11581120_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Move the rear door glass regulator (A) so that the bolt is visible through the hole in the door panel. Remove the bolt and remove the rear door glass (B) from the regulator holder (C)."
    },
    {
      "type": "figure",
      "asset": "735_3.0_jpn_11581121_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Raise the rear door glass (A) and hold it with tape (B) to prevent it from falling. Disconnect the coupler (C). Remove the rear door glass regulator (D)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Installation Precautions"
    },
    {
      "type": "figure",
      "asset": "735_3.0_jpn_11581122_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure. Apply grease to the sliding portion (B) of the rear door glass regulator (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Adjustment of rear door glass installation",
      "refs": [
        {
          "id": "R000741",
          "label": "Adjustment of rear door glass installation",
          "resolved": true
        }
      ]
    }
  ],
