          "label": "Catalytic Converter Removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. Remove P2 relief valve",
      "refs": [
        {
          "id": "R000419",
          "label": "Remove P2 relief valve",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. West gate control SOL.V. removal"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583048_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "9. Turbo charger in-pipe removal"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583049_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the boost hose (A) and purge tube (B) at the waste gate actuator. Remove the turbo charger in-pipe (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "10. Turbo charger out pipe removal"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583050_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the relief tube (A) and remove the turbocharger out pipe (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "11. Water pipe/oil return pipe removal"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583051_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the water pipe (A). Remove the oil return pipe (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "12. Remove oil feed pipe"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583052_5.0_disp.png"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "13. Turbo charger removal"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583053_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the turbo charger (A)."
    },
    {
      "type": "attention",
      "items": [
        "Do not have a waist gate section.",
        "Do not shock the turbo charger.",
        "Do not touch the impeller of the turbo charger.",
        "Seal the intake/exhaust and oil passages with duct tape to prevent dust and foreign matter from entering the removed turbocharger."
      ]
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Do not have a waist gate section."
        },
        {
          "text": "Do not have a waist gate section."
        },
        {
          "text": "Do not shock the turbo charger."
        },
        {
          "text": "Do not shock the turbo charger."
        },
        {
          "text": "Do not touch the impeller of the turbo charger."
        },
        {
          "text": "Do not touch the impeller of the turbo charger."
        },
        {
          "text": "Seal the intake/exhaust and oil passages with duct tape to prevent dust and foreign matter from entering the removed turbocharger."
        },
        {
          "text": "Seal the intake/exhaust and oil passages with duct tape to prevent dust and foreign matter from entering the removed turbocharger."
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Turbo Charger Installation"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583054_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Clean the mating surfaces of the packing and gasket of the turbocharger. Ensure that there are no foreign objects in the cylinder head and turbocharger in-pipe. Inject a small amount of oil through the oil hole (A) in the turbocharger. Install the turbocharger (C) using the new gasket (B)."
    },
    {
      "type": "attention",
      "items": [
        "When cleaning the mating surfaces of the packing and gasket, make sure that no debris from the packing or gasket enters the oil passage or intake/exhaust system passage."
      ]
    },
    {
      "type": "attention",
      "items": [
        "Do not have a waist gate section.",
        "Do not shock the turbo charger.",
        "Do not touch the impeller of the turbo charger."
      ]
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Do not have a waist gate section."
        },
        {
          "text": "Do not have a waist gate section."
        },
        {
          "text": "Do not shock the turbo charger."
        },
        {
          "text": "Do not shock the turbo charger."
        },
        {
          "text": "Do not touch the impeller of the turbo charger."
        },
        {
          "text": "Do not touch the impeller of the turbo charger."
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Oil Feed Pipe Installation"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583055_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the oil feed pipe (C) using a new washer (A) and a new O-ring (B)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Water Pipe/Oil Return Pipe Installation"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583056_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the water pipe (B) using a new gasket (A). Install the oil return pipe (D) using a new gasket (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Turbo charger out pipe installation"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583057_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the turbocharger out pipe (B) using the new gasket (A). Connect the relief tube (C)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Turbo charger in-pipe installation"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583058_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the turbocharger in-pipe (B) using the new gasket (A). Connect the boost hose (C) and purge tube (D) of the wastegate actuator."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "6. West Gate Control SOL.V. Installation"
    },
    {
      "type": "figure",
      "asset": "420_5.0_jpn_11583059_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install the waist gate control SOL.V. (B) using the new O-ring (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "7. P2 Relief Valve Installation",
      "refs": [
