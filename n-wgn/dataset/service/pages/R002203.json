          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "4. Rear seat cushion frame/slide adjuster removal"
    },
    {
      "type": "figure",
      "asset": "2203_3.0_jpn_11337263_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the cable band (A) and disconnect the control cable (D) from the rear seat cushion frame (B) and slide adjuster lever (C)."
    },
    {
      "type": "figure",
      "asset": "2203_3.0_jpn_11337264_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the rear seat upper rail cover (A)."
    },
    {
      "type": "figure",
      "asset": "2203_3.0_jpn_11337265_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the slide adjuster lever (A)."
    },
    {
      "type": "figure",
      "asset": "2203_3.0_jpn_11337266_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the rear seatback reclining strap (B) from the control cable (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "5. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
