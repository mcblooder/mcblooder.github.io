  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Tailgate lock removal"
    },
    {
      "type": "attention",
      "items": [
        "If the tailgate lock is not activated by using the Honda Smart Key or by operating the driver's side door lock, open the tailgate lock lid (A) and operate the tailgate lock lever (B) using a flathead screwdriver or similar tool as shown to unlock it and open the tailgate. If the tailgate lock does not work, open the tailgate lock lid (A)."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Tailgate lower lining removal",
      "refs": [
        {
          "id": "R000762",
          "label": "Tailgate lower lining removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Tailgate lock removal"
    },
    {
      "type": "figure",
      "asset": "832_3.0_jpn_11581478_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the coupler (A)."
    },
    {
      "type": "figure",
      "asset": "832_3.0_jpn_11581479_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Pull out and remove the tailgate lock (A)."
    },
    {
      "type": "figure",
      "asset": "832_3.0_jpn_11589053_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Disconnect the tailgate opener cable (B) from the tailgate lock (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
