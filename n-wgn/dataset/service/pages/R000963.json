    {
      "type": "heading",
      "level": 1,
      "text": "Headlight optical axis adjustment"
    },
    {
      "type": "attention",
      "items": [
        "Do not cover the entire surface of the outer lens of the headlight for more than 3 minutes because the headlight becomes hot when it is turned on.",
        "Since the outer lens of the headlight is made of resin, it may be deformed by heat if the lens is covered for a long time."
      ]
    },
    {
      "type": "paragraph",
      "text": "Items to check before inspection"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "The inspection site must be flat."
        },
        {
          "text": "The inspection site must be flat."
        },
        {
          "text": "The tire pressure must be at the specified pressure."
        },
        {
          "text": "The tire pressure must be at the specified pressure."
        },
        {
          "text": "One person must be in the driver's seat."
        },
        {
          "text": "One person must be in the driver's seat."
        },
        {
          "text": "No cargo other than puncture repair kits and on-board tools shall be loaded in the rear."
        },
        {
          "text": "No cargo other than puncture repair kits and on-board tools shall be loaded in the rear."
        },
        {
          "text": "For vehicles not equipped with discharge headlights, the headlight manual leveling switch shall be set to the 0 position to adjust the optical axis."
        },
        {
          "text": "For vehicles not equipped with discharge headlights, the headlight manual leveling switch shall be set to the 0 position to adjust the optical axis."
        }
      ]
    },
