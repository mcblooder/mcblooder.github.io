  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Front bumper removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Front bumper removal"
    },
    {
      "type": "figure",
      "asset": "814_3.0_jpn_11581437_3.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "814_3.0_jpn_11581438_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the front license plate. Remove the screws and clips (A, B)."
    },
    {
      "type": "figure",
      "asset": "814_3.0_jpn_11581439_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Pull the wheel arches on both sides of the front bumper (A) outward and remove them from the hooks (C) on the side spacers (B)."
    },
    {
      "type": "figure",
      "asset": "814_3.0_jpn_11581440_3.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "814_3.0_jpn_11581441_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the front bumper (C) from the hook (B) of the front upper grille (A)."
    },
    {
      "type": "figure",
      "asset": "814_3.0_jpn_11581442_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Custom: Disconnect the coupler (B) while holding the front bumper (A). Remove the front bumper."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Front bumper, side spacer removal"
    },
    {
      "type": "figure",
      "asset": "814_3.0_jpn_11581443_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "If necessary, remove the front bumper side spacers (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
