    },
    {
      "type": "figure",
      "asset": "2173_3.0_jpn_11582667_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the catalytic converter (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "8. Catalytic converter cover removal"
    },
    {
      "type": "figure",
      "asset": "2173_3.0_jpn_11582668_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the cover (B) and bracket (C) from the catalytic converter (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Catalytic Converter Cover Installation"
    },
    {
      "type": "figure",
      "asset": "2173_3.0_jpn_11582669_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Attach the cover (B) and bracket (C) to the catalytic converter (A)."
    },
    {
      "type": "attention",
      "items": [
        "Bolts (D) shall be temporarily tightened."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Catalytic Converter Installation"
    },
    {
      "type": "figure",
      "asset": "2173_3.0_jpn_11582670_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Tighten bolts and nuts (A). Tighten the bolts (B) in numerical order."
    },
    {
      "type": "attention",
      "items": [
        "Gasket (C) shall be replaced upon disassembly."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Cover Mounting"
