    {
      "type": "heading",
      "level": 1,
      "text": "Replace torque converter case input shaft bearing"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Input shaft bearing removal"
    },
    {
      "type": "figure",
      "asset": "580_3.0_jpn_11035249_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the input shaft bearing (A) using the bearing remover shaft, adjustable bearing remover 45-75 and sliding hammer weight."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Input shaft bearing mounting"
    },
    {
      "type": "figure",
      "asset": "580_3.0_jpn_11035250_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new bearing using the driver handle 15 x 135L and bearing driver attachment 72 x 75. Press-fit the bearing securely until it butts up against the case."
    }
  ],
