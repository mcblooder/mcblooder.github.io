  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Rear seat back trim cover/pad removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Rear seat removal",
      "refs": [
        {
          "id": "R000799",
          "label": "Rear seat removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Remove rear seat back trim cover/pad"
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11370736_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the rear seat center pivot cover B (A)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11337287_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the hook (B) from the rear seat cushion trim cover (A)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11337288_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the pivot cover (A)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11337289_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Remove the hook (A) and pull up the zipper (B)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11337290_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "5",
      "text": "Remove the hook (A)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11337291_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Remove the rear seat back trim cover (A) from the hook (B)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11390228_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Flip up the rear seat back trim cover/pad (A), remove the screw and hook (B), and remove the lever cover (C)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11390229_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "8",
      "text": "Remove the seat back reclining strap (A)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11390230_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "9",
      "text": "Remove the headrest guide (A)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11390231_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "10",
      "text": "Remove the rear seat back trim cover/pad (A) from the frame (B)."
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11337295_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "11",
      "text": "Flip up the rear seat back trim cover (A), remove the clip (B) on the inside of the cover, and separate the cover and pad."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "figure",
      "asset": "2175_3.0_jpn_11337296_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure. Replace the clip (A) on the rear seat back trim cover. Use seat handy pliers (B) (commercially available) for easier work."
    }
  ],
  "source": "sm_contents/60T6GD00_2014_jpn_RIN_20131015114331/Contents/jpn/60T6GD00_2014/RIN/SCT/SC/SYS/R002175_jpn/web/html/R002175_jpn_Content.html",
  "inOutline": true
}