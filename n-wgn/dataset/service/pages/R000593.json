    {
      "type": "heading",
      "level": 1,
      "text": "Differential Oil Seal Replacement"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Remove oil seal"
    },
    {
      "type": "figure",
      "asset": "593_4.0_jpn_11582447_4.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the oil seal (A) from the transmission case."
    },
    {
      "type": "figure",
      "asset": "593_4.0_jpn_11582448_4.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "2WD vehicles: Remove the oil seal (A) from the torque converter case."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Oil Seal Installation"
    },
    {
      "type": "figure",
      "asset": "593_4.0_jpn_11582449_4.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Using the 15 x 135L screwdriver handle and the 72 oil seal screwdriver attachment, align the new oil seal with the transmission case end face and install."
    },
    {
      "type": "figure",
      "asset": "593_4.0_jpn_11582450_4.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "2WD vehicles: Install a new oil seal using the driver handle 15 x 135L and the oil seal driver attachment 58, aligning it with the end face of the torque converter case."
    }
  ],
