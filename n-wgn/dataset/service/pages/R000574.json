    {
      "type": "heading",
      "level": 1,
      "text": "Transmission Case Input Shaft Holder Input Shaft Bearing Replacement"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Input shaft holder Input shaft bearing removal"
    },
    {
      "type": "figure",
      "asset": "574_3.0_jpn_11035228_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Remove the bearing set plate (A)."
    },
    {
      "type": "figure",
      "asset": "574_3.0_jpn_11035229_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the input shaft holder input shaft bearing (A) using the bearing remover shaft handle, sliding hammer weight, and bearing remover shaft set 20."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Input shaft holder Input shaft bearing mounting"
    },
    {
      "type": "figure",
      "asset": "574_3.0_jpn_11035230_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Install a new bearing using the driver handle 15 x 135L and the bearing driver attachment 40. Press-fit the bearing securely into the input shaft holder until it is pressed against the input shaft holder."
    },
    {
      "type": "figure",
      "asset": "574_3.0_jpn_11035231_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "2",
      "text": "Install the bearing set plate (A)."
    }
  ],
