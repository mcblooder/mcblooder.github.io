        ],
        [
          {
            "text": "I hear a warbling, warbling sound."
          },
          {
            "text": "Compressor whine"
          },
          {
            "text": "Compressor mounting bolts, etc., should be tightened properly."
          }
        ],
        [
          {
            "text": "Crank pulley noise"
          },
          {
            "text": "Rattling noise"
          },
          {
            "text": "Crank pulley sound (emitted during idling and rapid acceleration. The sound is especially loud when the compressor is turned on, so it can easily be mistaken for a compressor sound.)"
          },
          {
            "text": "Replace or (if no visual damage) retighten"
          }
        ],
        [
          {
            "text": "Noise from belt",
            "rowspan": 2
          },
          {
            "text": "I hear a continuous cueing sound."
          },
          {
            "text": "Belt is loose (belt runout is also significant)"
          },
          {
            "text": "Belt tension adjustment ​ belt replacement ​",
            "refs": [
              {
                "id": "R000432",
