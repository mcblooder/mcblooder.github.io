            "text": "Noise from component mounting area"
          },
          {
            "text": "Continuous gargling sound (rattling when touched)"
          },
          {
            "text": "Fixing bolt dropout or loosening Damage to brackets"
          },
          {
            "text": "Put into regular tightening condition. Brackets replaced"
          }
