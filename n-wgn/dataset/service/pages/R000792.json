  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Front seat removal"
    },
    {
      "type": "attention",
      "items": [
        "If there are components of the SRS airbag system in the vicinity, refer to the work precautions and configuration drawings described for the SRS airbag system before proceeding."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. 12V battery Negative (-) terminal Disconnect",
      "refs": [
        {
          "id": "R000910",
          "label": "12V battery Negative (-) terminal Disconnect",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Front seat removal"
    },
    {
      "type": "figure",
      "asset": "792_3.0_jpn_11581320_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Shift the seat forward. Remove the hook (A), and remove the outer rear foot cover (B) and inner rear foot cover (C)."
    },
    {
      "type": "figure",
      "asset": "792_3.0_jpn_11588271_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Remove the bolts (A, B)."
    },
    {
      "type": "figure",
      "asset": "792_3.0_jpn_11581322_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Shift the seat backward. Remove the hook (A), and remove the outer front foot cover (B) and inner front foot cover (C)."
    },
    {
      "type": "figure",
      "asset": "792_3.0_jpn_11588272_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "6",
      "text": "Remove the bolt."
    },
    {
      "type": "figure",
      "asset": "792_3.0_jpn_11581324_3.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "792_3.0_jpn_11581325_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "7",
      "text": "Tilt the front seat and disconnect the coupler (A)."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "figure",
      "asset": "792_3.0_jpn_11588273_2.0_disp.png"
    },
    {
      "type": "figure",
      "asset": "792_3.0_jpn_11588274_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Tighten the front seat mounting bolts to the specified torque value in the order shown in the figure after all bolts are temporarily tightened."
        },
        {
          "text": "Tighten the front seat mounting bolts to the specified torque value in the order shown in the figure after all bolts are temporarily tightened."
        },
        {
          "text": "The figure shows the driver's side seat, but the passenger side seat is tightened in an order that is symmetrical with the driver's side seat."
        },
        {
          "text": "The figure shows the driver's side seat, but the passenger side seat is tightened in an order that is symmetrical with the driver's side seat."
        }
      ]
    }
  ],
