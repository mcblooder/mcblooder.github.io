      "level": 1,
      "text": "Check cylinder head compression pressure"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "If a temporary DTC or DTC is displayed while performing this task, check the temporary DTC or DTC and erase it if necessary."
        },
        {
          "text": "If a temporary DTC or DTC is displayed while performing this task, check the temporary DTC or DTC and erase it if necessary."
        },
        {
          "text": "After the inspection is completed, reset the ECU with the Honda Diagnostics System (HDS) to deactivate the injector all-cylinder stop function."
        },
        {
          "text": "After the inspection is completed, reset the ECU with the Honda Diagnostics System (HDS) to deactivate the injector all-cylinder stop function."
