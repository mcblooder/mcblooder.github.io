    {
      "type": "heading",
      "level": 3,
      "text": "1. Engine Warming up"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Start the engine, operate the radiator fan twice, and then warm up the engine for at least 2 minutes at 3,000 rpm with no load. After warming up, stop the engine."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. HDS Connection"
    },
    {
      "type": "figure",
      "asset": "2130_3.0_jpn_11582747_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Connect HDS to the data link coupler (A) on the left side of the driver's seat."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Injectors All cylinders shut down"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Select the Injector All Cylinders Stop function from the HDS Inspect menu."
    },
