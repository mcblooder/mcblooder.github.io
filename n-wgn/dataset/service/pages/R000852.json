  "blocks": [
    {
      "type": "heading",
      "level": 1,
      "text": "Roof Mole Removal"
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Roof Mole Removal"
    },
    {
      "type": "figure",
      "asset": "852_3.0_jpn_11369505_3.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Apply the protective tape (A) on the body side to prevent scratching. Insert the handy remover (B) between the body and the roof molding (C). Pull up the roof molding with the handy remover and shift it backward to remove the front bracket (E) of the roof molding from the pin (D) on the body side."
    },
    {
      "type": "figure",
      "asset": "852_3.0_jpn_11382988_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "3",
      "text": "Pull up the roof molding (A) and remove it from the body."
    },
    {
      "type": "figure",
      "asset": "852_3.0_jpn_11369507_2.0_disp.png"
    },
    {
      "type": "step",
      "number": "4",
      "text": "Slide the roof molding (A) toward the front and remove the rear bracket (C) of the roof molding from the pin (B) on the body side, then remove the roof molding."
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    }
  ],
