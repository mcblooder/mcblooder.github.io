    {
      "type": "heading",
      "level": 1,
      "text": "Driven Pulley oil pressure sensor removal"
    },
    {
      "type": "attention",
      "items": [
        "Be very careful to prevent dust and other debris from entering the transmission."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "1. Left side front splash guard removal",
      "refs": [
        {
          "id": "R000849",
          "label": "Left side front splash guard removal",
          "resolved": true
        }
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "2. Remove drive pulley oil pressure sensor"
    },
    {
      "type": "figure",
      "asset": "536_5.0_jpn_11582164_5.0_disp.png"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Disconnect the coupler (A)."
    },
    {
      "type": "step",
      "number": "2",
      "text": "Remove the driven pulley oil pressure sensor (B) and sealing washer (C)."
    },
    {
      "type": "attention",
      "items": [
        "Be careful not to damage the plastic part of the sensor."
      ]
    },
    {
      "type": "heading",
      "level": 3,
      "text": "3. Installation Precautions"
    },
    {
      "type": "step",
      "number": "1",
      "text": "Installation is the reverse of the removal procedure."
    },
    {
      "type": "attention",
      "items": [
        "The sealing washers shall be replaced with new ones."
      ]
    }
  ],
